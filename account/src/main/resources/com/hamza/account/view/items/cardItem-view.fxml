<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<AnchorPane nodeOrientation="RIGHT_TO_LEFT"
            styleClass="items-root"
            stylesheets="@../../css/items-modern.css"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21">
    <children>
        <VBox fx:id="box"
              spacing="14.0"
              styleClass="items-container"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <children>
                <VBox styleClass="items-card">
                    <children>
                        <GridPane hgap="12.0" vgap="12.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="110.0"/>
                                <ColumnConstraints minWidth="220.0" hgrow="ALWAYS"/>
                                <ColumnConstraints minWidth="110.0"/>
                                <ColumnConstraints minWidth="220.0" hgrow="ALWAYS"/>
                            </columnConstraints>

                            <children>
                                <Label fx:id="labelName" text="Name" styleClass="form-label"/>
                                <TextField fx:id="textName"
                                           editable="false"
                                           GridPane.columnIndex="1"/>

                                <Label fx:id="labelType"
                                       text="Type"
                                       styleClass="form-label"
                                       GridPane.columnIndex="2"/>
                                <ComboBox fx:id="comboBox"
                                          maxWidth="1.7976931348623157E308"
                                          GridPane.columnIndex="3"/>

                                <Label fx:id="labelFrom"
                                       text="From"
                                       styleClass="form-label"
                                       GridPane.rowIndex="1"/>
                                <DatePicker fx:id="dateFrom"
                                            editable="false"
                                            maxWidth="1.7976931348623157E308"
                                            GridPane.columnIndex="1"
                                            GridPane.rowIndex="1"/>

                                <Label fx:id="labelTo"
                                       text="To"
                                       styleClass="form-label"
                                       GridPane.columnIndex="2"
                                       GridPane.rowIndex="1"/>
                                <DatePicker fx:id="dateTo"
                                            editable="false"
                                            maxWidth="1.7976931348623157E308"
                                            GridPane.columnIndex="3"
                                            GridPane.rowIndex="1"/>

                                <Label text="الوحدة الأساسية"
                                       styleClass="form-label"
                                       GridPane.rowIndex="2"/>
                                <Text fx:id="textType"
                                      strokeType="OUTSIDE"
                                      strokeWidth="0.0"
                                      text="قطعة"
                                      styleClass="summary-value"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="2"/>

                                <HBox alignment="CENTER_LEFT"
                                      spacing="8.0"
                                      GridPane.columnIndex="3"
                                      GridPane.rowIndex="2">
                                    <children>
                                        <Button fx:id="btnSearch"
                                                mnemonicParsing="false"
                                                text="Search"
                                                styleClass="primary-button"/>
                                        <Button fx:id="btnPrint"
                                                mnemonicParsing="false"
                                                text="Print"
                                                styleClass="neutral-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <TableView fx:id="tableView"
                           styleClass="modern-table"
                           VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="summary-bar">
                    <children>
                        <GridPane hgap="10.0" vgap="8.0" HBox.hgrow="ALWAYS">
                            <columnConstraints>
                                <ColumnConstraints minWidth="110.0"/>
                                <ColumnConstraints minWidth="90.0"/>
                                <ColumnConstraints minWidth="110.0"/>
                                <ColumnConstraints minWidth="90.0"/>
                                <ColumnConstraints minWidth="150.0"/>
                                <ColumnConstraints minWidth="90.0"/>
                                <ColumnConstraints minWidth="150.0"/>
                                <ColumnConstraints minWidth="90.0"/>
                                <ColumnConstraints minWidth="110.0"/>
                                <ColumnConstraints minWidth="100.0"/>
                            </columnConstraints>

                            <children>
                                <Label fx:id="labelPurchase" text="Purchase" styleClass="summary-label"/>
                                <Text fx:id="textPurchase" text="0.0" styleClass="summary-value" GridPane.columnIndex="1"/>

                                <Label fx:id="labelSales" text="Sales" styleClass="summary-label" GridPane.columnIndex="2"/>
                                <Text fx:id="textSales" text="0.0" styleClass="summary-value" GridPane.columnIndex="3"/>

                                <Label fx:id="labelRePurchase" text="Return Purchase" styleClass="summary-label" GridPane.columnIndex="4"/>
                                <Text fx:id="textRePurchase" text="0.0" styleClass="summary-value" GridPane.columnIndex="5"/>

                                <Label fx:id="labelReSales" text="Return Sales" styleClass="summary-label" GridPane.columnIndex="6"/>
                                <Text fx:id="textReSales" text="0.0" styleClass="summary-value" GridPane.columnIndex="7"/>

                                <Label text="إجمالي الكمية" styleClass="summary-label" GridPane.columnIndex="8"/>
                                <Text fx:id="textCountTotals" text="0.0" styleClass="summary-value" GridPane.columnIndex="9"/>

                                <Label text="إجمالي الشراء" styleClass="summary-label" GridPane.rowIndex="1"/>
                                <Text fx:id="textCostPurchase" text="0.0" styleClass="summary-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="إجمالي البيع" styleClass="summary-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                <Text fx:id="textCostSales" text="0.0" styleClass="summary-value" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                                <Label text="إجمالي مرتجع المشتريات" styleClass="summary-label" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                                <Text fx:id="textCostPurchaseRe" text="0.0" styleClass="summary-value" GridPane.columnIndex="5" GridPane.rowIndex="1"/>

                                <Label text="إجمالي مرتجع المبيعات" styleClass="summary-label" GridPane.columnIndex="6" GridPane.rowIndex="1"/>
                                <Text fx:id="textCostSalesRe" text="0.0" styleClass="summary-value" GridPane.columnIndex="7" GridPane.rowIndex="1"/>

                                <Label text="ربح الصنف" styleClass="summary-label" GridPane.columnIndex="8" GridPane.rowIndex="1"/>
                                <Text fx:id="textCostTotals" text="0.0" styleClass="summary-value" GridPane.columnIndex="9" GridPane.rowIndex="1"/>
                            </children>
                        </GridPane>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>