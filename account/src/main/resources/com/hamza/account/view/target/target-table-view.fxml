<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Button fx:id="btnPrint" mnemonicParsing="false" text="طباعة"/>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="المدفوع"/>
                                <Text fx:id="textSumPayment" strokeType="OUTSIDE" strokeWidth="0.0" text="0"/>
                                <Label text="الباقي"/>
                                <Text fx:id="textSumAmount" strokeType="OUTSIDE" strokeWidth="0.0" text="0"/>
                            </children>
                            <padding>
                                <Insets bottom="1.0" left="1.0" right="1.0" top="1.0"/>
                            </padding>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="2.0" left="2.0" right="2.0" top="2.0"/>
                    </padding>
                </HBox>
                <TableView fx:id="tableView" VBox.vgrow="SOMETIMES"/>
            </children>
        </VBox>
    </children>
</AnchorPane>
