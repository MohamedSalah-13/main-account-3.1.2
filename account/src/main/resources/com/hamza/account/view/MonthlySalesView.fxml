<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hamza.account.controller.reports.MonthlySalesController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <Label fx:id="title" text="تقرير المبيعات الشهرية لكل سنة" textFill="#2c3e50" underline="true">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            <HBox alignment="TOP_RIGHT" spacing="10.0">
               <children>
      
                      <Button onAction="#onExportPdf" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="تصدير PDF">
                          <font>
                              <Font name="System Bold" size="13.0" />
                          </font>
                      </Button>
                      <Button onAction="#onExportExcel" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="تصدير Excel">
                          <font>
                              <Font name="System Bold" size="13.0" />
                          </font>
                      </Button>
               </children>
            </HBox>

                <BarChart fx:id="chartSales" prefHeight="350.0" title="مقارنة المبيعات بين الشهور">
                    <xAxis>
                        <CategoryAxis label="الشهور" side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="القيمة المالية" side="LEFT" />
                    </yAxis>
                </BarChart>

                <TableView fx:id="tableSales" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colYear" prefWidth="75.0" text="السنة" />
                        <TableColumn fx:id="colJan" prefWidth="75.0" text="يناير" />
                        <TableColumn fx:id="colFeb" prefWidth="75.0" text="فبراير" />
                        <TableColumn fx:id="colMar" prefWidth="75.0" text="مارس" />
                        <TableColumn fx:id="colApr" prefWidth="75.0" text="أبريل" />
                        <TableColumn fx:id="colMay" prefWidth="75.0" text="مايو" />
                        <TableColumn fx:id="colJun" prefWidth="75.0" text="يونيو" />
                        <TableColumn fx:id="colJul" prefWidth="75.0" text="يوليو" />
                        <TableColumn fx:id="colAug" prefWidth="75.0" text="أغسطس" />
                        <TableColumn fx:id="colSep" prefWidth="75.0" text="سبتمبر" />
                        <TableColumn fx:id="colOct" prefWidth="75.0" text="أكتوبر" />
                        <TableColumn fx:id="colNov" prefWidth="75.0" text="نوفمبر" />
                        <TableColumn fx:id="colDec" prefWidth="75.0" text="ديسمبر" />
                        <TableColumn fx:id="colTotal" prefWidth="120.0" style="-fx-font-weight: bold; -fx-background-color: #ecf0f1;" text="إجمالي السنة" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
