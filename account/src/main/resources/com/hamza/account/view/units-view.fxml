<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:id="stackPane" xmlns="http://javafx.com/javafx/21">
    <children>
        <AnchorPane prefHeight="470.0" prefWidth="832.0">
            <children>
                <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                      AnchorPane.topAnchor="0.0">
                    <children>
                        <ToolBar prefHeight="40.0" prefWidth="200.0">
                            <items>
                                <Button fx:id="btnSave" defaultButton="true" mnemonicParsing="false" text="Save"/>
                                <Button fx:id="btnClear" mnemonicParsing="false" text="Clear"/>
                                <Button fx:id="btnRefresh" layoutX="57.0" layoutY="10.0" mnemonicParsing="false"
                                        text="refresh"/>
                                <Separator orientation="VERTICAL"/>
                                <Button fx:id="btnClose" cancelButton="true" mnemonicParsing="false" text="Close"/>
                            </items>
                        </ToolBar>
                        <VBox spacing="2.0" VBox.vgrow="SOMETIMES">
                            <children>
                                <VBox minHeight="-Infinity" styleClass="dashboard-tile">
                                    <children>
                                        <HBox minHeight="-Infinity" minWidth="-Infinity" spacing="5.0">
                                            <children>
                                                <GridPane styleClass="grid-pane-style" HBox.hgrow="SOMETIMES">
                                                    <columnConstraints>
                                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                           minWidth="10.0"/>
                                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                           minWidth="10.0"/>
                                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                           minWidth="10.0"/>
                                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                           minWidth="10.0"/>
                                                    </columnConstraints>
                                                    <rowConstraints>
                                                        <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                        vgrow="SOMETIMES"/>
                                                        <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                        vgrow="SOMETIMES"/>
                                                    </rowConstraints>
                                                    <children>
                                                        <Label fx:id="labelCode" text="Code"/>
                                                        <Label fx:id="labelName" text="Name" GridPane.columnIndex="2"/>
                                                        <Label fx:id="labelQuantity" text="Quantity"
                                                               GridPane.rowIndex="1"/>
                                                        <TextField fx:id="textCode" disable="true" editable="false"
                                                                   GridPane.columnIndex="1"/>
                                                        <TextField fx:id="textName" GridPane.columnIndex="3"/>
                                                        <TextField fx:id="textCount" GridPane.columnIndex="1"
                                                                   GridPane.rowIndex="1"/>
                                                    </children>
                                                </GridPane>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <TableView fx:id="tableView" VBox.vgrow="SOMETIMES"/>
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0"/>
                            </padding>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</StackPane>
