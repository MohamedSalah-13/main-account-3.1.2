<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import org.controlsfx.control.SearchableComboBox?>

<StackPane fx:id="stackPane"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           styleClass="page-root">

    <AnchorPane>
        <VBox spacing="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <ToolBar styleClass="main-toolbar">
                <Button fx:id="btnSave"
                        mnemonicParsing="false"
                        prefWidth="95.0"
                        styleClass="primary-button"
                        text="حفظ"/>

                <Button fx:id="btnPrint"
                        mnemonicParsing="false"
                        prefWidth="95.0"
                        styleClass="secondary-button"
                        text="طباعة"/>

                <Separator orientation="VERTICAL"/>

                <Button fx:id="btnClear"
                        mnemonicParsing="false"
                        prefWidth="95.0"
                        styleClass="secondary-button"
                        text="مسح"/>

                <Button fx:id="btnAddStock"
                        mnemonicParsing="false"
                        prefWidth="120.0"
                        styleClass="success-button"
                        text="إضافة مخزن"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label styleClass="screen-title" text="تحويلات المخازن"/>
            </ToolBar>

            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>

                <VBox spacing="12.0" styleClass="dashboard-tile">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
                    </padding>

                    <Label styleClass="section-title" text="بيانات التحويل"/>

                    <GridPane fx:id="gridPane"
                              hgap="10.0"
                              vgap="10.0">

                        <columnConstraints>
                            <ColumnConstraints minWidth="90.0" prefWidth="110.0"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="170.0" prefWidth="230.0"/>
                            <ColumnConstraints minWidth="90.0" prefWidth="110.0"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="170.0" prefWidth="230.0"/>
                            <ColumnConstraints minWidth="90.0" prefWidth="110.0"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="170.0" prefWidth="230.0"/>
                        </columnConstraints>

                        <rowConstraints>
                            <RowConstraints minHeight="38.0" prefHeight="42.0"/>
                            <RowConstraints minHeight="38.0" prefHeight="42.0"/>
                        </rowConstraints>

                        <Label styleClass="form-label" text="كود التحويل"/>
                        <TextField fx:id="txtCode"
                                   editable="false"
                                   focusTraversable="false"
                                   text="0"
                                   GridPane.columnIndex="1"/>

                        <Label styleClass="form-label"
                               text="التاريخ"
                               GridPane.columnIndex="2"/>
                        <DatePicker fx:id="convertDate"
                                    maxWidth="Infinity"
                                    GridPane.columnIndex="3"/>

                        <Label styleClass="form-label"
                               text="من مخزن"
                               GridPane.rowIndex="1"/>
                        <SearchableComboBox fx:id="comboFromStock"
                                            maxWidth="Infinity"
                                            prefWidth="230.0"
                                            GridPane.columnIndex="1"
                                            GridPane.rowIndex="1"/>

                        <Label styleClass="form-label"
                               text="إلى مخزن"
                               GridPane.columnIndex="2"
                               GridPane.rowIndex="1"/>
                        <SearchableComboBox fx:id="comboToStock"
                                            maxWidth="Infinity"
                                            prefWidth="230.0"
                                            GridPane.columnIndex="3"
                                            GridPane.rowIndex="1"/>

                        <Label styleClass="hint-label"
                               text="اختر المخزن المصدر أولاً، ثم ابحث عن الأصناف وأضفها للتحويل"
                               GridPane.columnIndex="4"
                               GridPane.columnSpan="2"
                               GridPane.rowIndex="1"/>
                    </GridPane>
                </VBox>

                <SplitPane dividerPositions="0.42"
                           VBox.vgrow="ALWAYS">

                    <VBox spacing="8.0" styleClass="dashboard-tile">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="section-title" text="بحث الأصناف"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button fx:id="btnAddSelectedItems"
                                    mnemonicParsing="false"
                                    prefWidth="130.0"
                                    styleClass="primary-button"
                                    text="إضافة المحدد"/>

                            <Button fx:id="btnAddAllItems"
                                    mnemonicParsing="false"
                                    prefWidth="130.0"
                                    styleClass="success-button"
                                    text="إضافة النتائج"/>
                        </HBox>

                        <TextField fx:id="txtItemsSearch"
                                   promptText="ابحث باسم الصنف أو الباركود..."
                                   VBox.vgrow="NEVER"/>

                        <TableView fx:id="itemsSearchTable"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="modern-table"/>

                        <Label styleClass="hint-label"
                               text="يمكن تحديد أكثر من صنف من الجدول ثم الضغط على إضافة المحدد"/>
                    </VBox>

                    <VBox spacing="8.0" styleClass="dashboard-tile">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="section-title" text="الأصناف المحولة"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button fx:id="btnRemoveSelected"
                                    mnemonicParsing="false"
                                    prefWidth="120.0"
                                    styleClass="danger-button"
                                    text="حذف المحدد"/>

                            <Button fx:id="btnClearItems"
                                    mnemonicParsing="false"
                                    prefWidth="110.0"
                                    styleClass="secondary-button"
                                    text="مسح الأصناف"/>
                        </HBox>

                        <TableView fx:id="tableView"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="modern-table"/>

                        <HBox alignment="CENTER_LEFT"
                              spacing="16.0"
                              styleClass="summary-card">
                            <padding>
                                <Insets bottom="10.0" left="14.0" right="14.0" top="10.0"/>
                            </padding>

                            <Label styleClass="summary-label" text="عدد الأصناف"/>
                            <Text fx:id="stockCount"
                                  strokeType="OUTSIDE"
                                  strokeWidth="0.0"
                                  styleClass="text-sum"
                                  text="0"/>

                            <Separator orientation="VERTICAL"/>

                            <Label styleClass="summary-label" text="إجمالي الكميات"/>
                            <Text fx:id="stockTotal"
                                  strokeType="OUTSIDE"
                                  strokeWidth="0.0"
                                  styleClass="text-sum"
                                  text="0"/>
                        </HBox>
                    </VBox>
                </SplitPane>
            </VBox>
        </VBox>
    </AnchorPane>
</StackPane>