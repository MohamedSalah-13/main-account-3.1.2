<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane nodeOrientation="RIGHT_TO_LEFT" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hamza.account.controller.reports.ItemSalesRankController">
    <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="app-card" BorderPane.alignment="CENTER">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="report-title" text="تقرير حركة الأصناف" />
                                <Label styleClass="report-subtitle" text="الأصناف الأكثر والأقل مبيعاً حسب الشهر والسنة" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Label styleClass="form-label" text="السنة:" />
                        <ComboBox fx:id="comboYear" prefWidth="100.0" />

                        <Label styleClass="form-label" text="الشهر:" />
                        <ComboBox fx:id="comboMonth" prefWidth="120.0" />

                        <Button mnemonicParsing="false" onAction="#searchAction" styleClass="primary-button" text="بحث وعرض" />

                        <Button onAction="#onExportPdf" styleClass="pdf-button" text="PDF" />
                        <Button onAction="#onExportExcel" styleClass="excel-button" text="Excel" />
                    </children>
                </HBox>
         </top>
         <center>
              <VBox spacing="16.0" styleClass="app-container">
                  <children>
      
                                  <SplitPane dividerPositions="0.6" minHeight="-Infinity" minWidth="-Infinity" styleClass="modern-split-pane" VBox.vgrow="ALWAYS">
                          <items>
                              <VBox spacing="10.0" styleClass="chart-card">
                                  <children>
                                      <Label styleClass="section-title" text="التفاصيل - اضغط على اسم العمود للترتيب" />
                                      <TableView fx:id="tableView" minHeight="-Infinity" minWidth="-Infinity" prefHeight="250.0" prefWidth="300.0" styleClass="app-table" VBox.vgrow="ALWAYS">
                                          <columns>
                                              <TableColumn fx:id="colItemName" prefWidth="250.0" text="اسم الصنف" />
                                              <TableColumn fx:id="colTotalQty" prefWidth="120.0" text="الكمية المباعة" />
                                              <TableColumn fx:id="colTotalAmount" prefWidth="150.0" text="إجمالي المبيعات" />
                                              <TableColumn fx:id="colTotalProfit" prefWidth="150.0" text="صافي الربح" />
                                          </columns>
                                          <columnResizePolicy>
                                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                          </columnResizePolicy>
                                      </TableView>
                                  </children>
                              </VBox>
      
                                          <VBox alignment="TOP_CENTER" spacing="10.0" styleClass="chart-card">
                                  <children>
                                      <Label styleClass="section-title" text="أعلى 10 أصناف مبيعاً - بالكمية" />
                                      <PieChart fx:id="pieChartBestSellers" title="الأكثر مبيعاً" VBox.vgrow="ALWAYS" />
                                  </children>
                              </VBox>
                          </items>
                      </SplitPane>
                  </children>
              </VBox>
         </center>
      </BorderPane>
    </children>
</AnchorPane>
