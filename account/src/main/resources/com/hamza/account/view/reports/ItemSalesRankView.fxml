<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0"
            prefWidth="1100.0"
            nodeOrientation="RIGHT_TO_LEFT"
            styleClass="app-root"

            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hamza.account.controller.reports.ItemSalesRankController">
    <children>
        <VBox spacing="16.0"
              styleClass="app-container"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="app-card">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="تقرير حركة الأصناف" styleClass="report-title"/>
                                <Label text="الأصناف الأكثر والأقل مبيعاً حسب الشهر والسنة" styleClass="report-subtitle"/>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="السنة:" styleClass="form-label"/>
                        <ComboBox fx:id="comboYear" prefWidth="100.0"/>

                        <Label text="الشهر:" styleClass="form-label"/>
                        <ComboBox fx:id="comboMonth" prefWidth="120.0"/>

                        <Button mnemonicParsing="false"
                                onAction="#searchAction"
                                text="بحث وعرض"
                                styleClass="primary-button"/>

                        <Button onAction="#onExportPdf" text="PDF" styleClass="pdf-button"/>
                        <Button onAction="#onExportExcel" text="Excel" styleClass="excel-button"/>
                    </children>
                </HBox>

                <SplitPane dividerPositions="0.6"
                           styleClass="modern-split-pane"
                           VBox.vgrow="ALWAYS">
                    <items>
                        <VBox spacing="10.0" styleClass="chart-card">
                            <children>
                                <Label text="التفاصيل - اضغط على اسم العمود للترتيب" styleClass="section-title"/>
                                <TableView fx:id="tableView" styleClass="app-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colItemName" prefWidth="250.0" text="اسم الصنف"/>
                                        <TableColumn fx:id="colTotalQty" prefWidth="120.0" text="الكمية المباعة"/>
                                        <TableColumn fx:id="colTotalAmount" prefWidth="150.0" text="إجمالي المبيعات"/>
                                        <TableColumn fx:id="colTotalProfit" prefWidth="150.0" text="صافي الربح"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox alignment="TOP_CENTER" spacing="10.0" styleClass="chart-card">
                            <children>
                                <Label text="أعلى 10 أصناف مبيعاً - بالكمية" styleClass="section-title"/>
                                <PieChart fx:id="pieChartBestSellers"
                                          title="الأكثر مبيعاً"
                                          VBox.vgrow="ALWAYS"/>
                            </children>
                        </VBox>
                    </items>
                </SplitPane>
            </children>
        </VBox>
    </children>
</AnchorPane>