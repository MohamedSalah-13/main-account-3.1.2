<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hamza.account.controller.reports.ItemSalesRankController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-background-radius: 5;">
                    <children>
                        <Label text="تقرير حركة الأصناف (الأكثر والأقل مبيعاً)" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>
                        <HBox HBox.hgrow="ALWAYS" /> <Label text="السنة:">
                        <font><Font name="System Bold" size="14.0" /></font>
                    </Label>
                        <ComboBox fx:id="comboYear" prefWidth="100.0" />

                        <Label text="الشهر:">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <ComboBox fx:id="comboMonth" prefWidth="120.0" />

                        <Button mnemonicParsing="false" onAction="#searchAction" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="بحث وعرض">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>

                <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
                    <items>
                        <VBox spacing="10.0">
                            <children>
                                <Label text="التفاصيل (اضغط على اسم العمود للترتيب)" textFill="#7f8c8d">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colItemName" prefWidth="250.0" text="اسم الصنف" />
                                        <TableColumn fx:id="colTotalQty" prefWidth="120.0" text="الكمية المباعة" />
                                        <TableColumn fx:id="colTotalAmount" prefWidth="150.0" text="إجمالي المبيعات" />
                                        <TableColumn fx:id="colTotalProfit" prefWidth="150.0" text="صافي الربح" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </padding>
                        </VBox>

                        <VBox alignment="TOP_CENTER" spacing="10.0">
                            <children>
                                <Label text="أعلى 10 أصناف مبيعاً (بالكمية)" textFill="#7f8c8d">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <PieChart fx:id="pieChartBestSellers" title="الأكثر مبيعاً" VBox.vgrow="ALWAYS" />
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </padding>
                        </VBox>
                    </items>
                </SplitPane>
            </children>
        </VBox>
    </children>
</AnchorPane>