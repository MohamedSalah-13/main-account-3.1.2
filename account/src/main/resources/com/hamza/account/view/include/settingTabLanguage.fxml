<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane nodeOrientation="RIGHT_TO_LEFT" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="settings-scroll-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="18.0" styleClass="app-container">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="settings-title" text="إعدادات النظام" />
                                <Label styleClass="settings-subtitle" text="اللغة والثيم والطابعات والعملاء الافتراضيين" />
                            </children>
                        </VBox>

                        <GridPane hgap="5.0" styleClass="app-card" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="170.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="360.0" />
                                <ColumnConstraints minWidth="170.0" />
                            </columnConstraints>

                            <children>
                                <Label styleClass="form-label" text="Choose theme for Desktop" />
                                <HBox alignment="CENTER_LEFT" spacing="24.0" GridPane.columnIndex="1">
                                    <children>
                                        <RadioButton fx:id="radioLight" mnemonicParsing="false" styleClass="modern-radio" text="light">
                                            <toggleGroup>
                                                <ToggleGroup fx:id="group" />
                                            </toggleGroup>
                                        </RadioButton>
                                        <RadioButton fx:id="radioDark" mnemonicParsing="false" styleClass="modern-radio" text="Dark" toggleGroup="$group" />
                                        <RadioButton fx:id="radioSystem" mnemonicParsing="false" selected="true" styleClass="modern-radio" text="Use system settings" toggleGroup="$group" />
                                    </children>
                                </HBox>

                                <Label fx:id="labelLanguage" styleClass="form-label" text="Language" GridPane.rowIndex="1" />
                                <HBox alignment="CENTER_LEFT" disable="true" spacing="24.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <RadioButton fx:id="radioArabic" mnemonicParsing="false" selected="true" styleClass="modern-radio" text="Arabic">
                                            <toggleGroup>
                                                <ToggleGroup fx:id="group1" />
                                            </toggleGroup>
                                        </RadioButton>
                                        <RadioButton fx:id="radioEnglish" mnemonicParsing="false" styleClass="modern-radio" text="English" toggleGroup="$group1" />
                                    </children>
                                </HBox>

                                <Label fx:id="labelPath" styleClass="form-label" text="Image Path" GridPane.rowIndex="2" />
                                <Label fx:id="textPath" maxWidth="320.0" styleClass="settings-subtitle" text="لا يوجد" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                <HBox alignment="CENTER_LEFT" spacing="6.0" GridPane.columnIndex="2" GridPane.rowIndex="2">
                                    <children>
                                        <Button fx:id="btnPath" mnemonicParsing="false" styleClass="icon-button" text="..." />
                                        <Button fx:id="btnDeleteImage" mnemonicParsing="false" styleClass="danger-button" text="Button" />
                                    </children>
                                </HBox>

                                <Label styleClass="form-label" text="فاتورة المبيعات" GridPane.rowIndex="3" />
                                <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="info-text" text="يتم تثبيت العميل والمندوب فى كل فاتورة بيع" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label styleClass="form-label" text="العميل" GridPane.rowIndex="4" />
                                <TextField fx:id="txtNameCustomer" disable="true" editable="false" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                <Button fx:id="btnSaveCustomer" mnemonicParsing="false" styleClass="icon-button" text="..." GridPane.columnIndex="2" GridPane.rowIndex="4" />

                                <Label styleClass="form-label" text="المندوب" GridPane.rowIndex="5" />
                                <TextField fx:id="txtNameDelegate" disable="true" editable="false" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                <Button fx:id="btnSaveDelegate" mnemonicParsing="false" styleClass="icon-button" text="..." GridPane.columnIndex="2" GridPane.rowIndex="5" />

                                <Label fx:id="labelRate" styleClass="form-label" text="Rate" GridPane.rowIndex="6" />
                                <TextField fx:id="textRateSel" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                <Label fx:id="labelMiniRate" styleClass="form-label" text="اعادة مسلسل الطابعة كل" GridPane.rowIndex="7" />
                                <TextField fx:id="textSerial" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                                <Label fx:id="labelCurrency" styleClass="form-label" text="Currency" GridPane.rowIndex="8" />
                                <ComboBox fx:id="comboCurrency" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                                <Label fx:id="labelPrintNormal" styleClass="form-label" text="Normal Printer" GridPane.rowIndex="9" />
                                <TextField fx:id="textPrintNormal" editable="false" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="9" />
                                <HBox alignment="CENTER_LEFT" spacing="6.0" GridPane.columnIndex="2" GridPane.rowIndex="9">
                                    <children>
                                        <Button fx:id="btnPrintNormal" mnemonicParsing="false" styleClass="icon-button" text="..." />
                                        <Button fx:id="btnPrinterSettingNormal" mnemonicParsing="false" styleClass="neutral-button" text="Setting" />
                                    </children>
                                </HBox>

                                <Label fx:id="labelPrintBarcode" styleClass="form-label" text="Barcode Printer" GridPane.rowIndex="10" />
                                <TextField fx:id="textPrintBarcode" editable="false" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="10" />
                                <HBox alignment="CENTER_LEFT" spacing="6.0" GridPane.columnIndex="2" GridPane.rowIndex="10">
                                    <children>
                                        <Button fx:id="btnPrintBarcode" mnemonicParsing="false" styleClass="icon-button" text="..." />
                                        <Button fx:id="btnPrinterSettingBarcode" mnemonicParsing="false" styleClass="neutral-button" text="Setting" />
                                    </children>
                                </HBox>

                                <Label fx:id="labelPrintOther" styleClass="form-label" text="Other Printer" GridPane.rowIndex="11" />
                                <TextField fx:id="textPrintOther" editable="false" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="11" />
                                <HBox alignment="CENTER_LEFT" spacing="6.0" GridPane.columnIndex="2" GridPane.rowIndex="11">
                                    <children>
                                        <Button fx:id="btnPrintOther" mnemonicParsing="false" styleClass="icon-button" text="..." />
                                        <Button fx:id="btnPrinterSettingOther" mnemonicParsing="false" styleClass="neutral-button" text="Setting" />
                                    </children>
                                </HBox>
                            </children>
                     <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                     </rowConstraints>
                        </GridPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
