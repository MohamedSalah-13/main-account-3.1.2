                                                                <Text fx:id="txtBeforeDiscount" strokeType="OUTSIDE"
                                                                      strokeWidth="0.0" styleClass="text-sum" text="0"
                                                                      GridPane.columnIndex="3"/>
                                                                <Label fx:id="last4" text="Label"
                                                                       GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                                                <Text fx:id="txtSumDiscount" strokeType="OUTSIDE"
                                                                      strokeWidth="0.0" styleClass="text-sum" text="0"
                                                                      GridPane.columnIndex="3" GridPane.rowIndex="1"/>
