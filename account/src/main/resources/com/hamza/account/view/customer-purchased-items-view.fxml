<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0"
            prefWidth="1200.0"
            nodeOrientation="RIGHT_TO_LEFT"
            styleClass="reports-root"
            stylesheets="@../css/reports-modern.css"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21">

    <top>
        <VBox spacing="16.0" styleClass="reports-container" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="report-header-card">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label fx:id="title"
                                       text="الأصناف المشتراة من العميل"
                                       styleClass="report-title"/>
                                <Label text="عرض وتحليل الأصناف التي اشتراها العميل خلال فترة محددة"
                                       styleClass="report-subtitle"/>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox spacing="18.0" styleClass="stats-bar">
                            <children>
                                <VBox alignment="CENTER" spacing="3.0">
                                    <children>
                                        <Label text="عدد السطور" styleClass="stat-title"/>
                                        <Label fx:id="labelCount" text="0" styleClass="stat-value"/>
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER" spacing="3.0">
                                    <children>
                                        <Label text="إجمالي البيع" styleClass="stat-title"/>
                                        <Label fx:id="labelTotalSales" text="0" styleClass="stat-value"/>
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER" spacing="3.0">
                                    <children>
                                        <Label text="إجمالي الكمية" styleClass="stat-title"/>
                                        <Label fx:id="labelTotalQuantity" text="0" styleClass="stat-value"/>
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER" spacing="3.0">
                                    <children>
                                        <Label text="صافي الإجمالي" styleClass="stat-title"/>
                                        <Label fx:id="labelNetTotal" text="0" styleClass="stat-value"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="customer-card">
                    <children>
                        <Label text="العميل:" styleClass="form-label"/>
                        <Label fx:id="labelCustomerName" text="" styleClass="customer-name"/>
                    </children>
                </HBox>

                <FlowPane hgap="10.0" vgap="10.0" styleClass="flow-filter-card">
                    <children>
                        <Label text="من:" styleClass="form-label"/>
                        <DatePicker fx:id="dateFrom"/>

                        <Label text="إلى:" styleClass="form-label"/>
                        <DatePicker fx:id="dateTo"/>

                        <Label text="اسم الصنف:" styleClass="form-label"/>
                        <TextField fx:id="textSearchName"
                                   promptText="ابحث بالاسم"
                                   styleClass="modern-input"/>

                        <Button fx:id="btnSearch" text="بحث" styleClass="primary-button"/>
                        <Button fx:id="btnReset" text="إعادة ضبط" styleClass="neutral-button"/>
                        <Button fx:id="btnSortDate" text="ترتيب حسب التاريخ" styleClass="warning-button"/>
                        <Button fx:id="btnExportExcel" text="تصدير Excel" styleClass="excel-button"/>
                        <Button fx:id="btnExportPdf" text="تصدير PDF" styleClass="pdf-button"/>
                    </children>
                </FlowPane>
            </children>
        </VBox>
    </top>

    <center>
        <VBox styleClass="reports-container">
            <children>
                <TableView fx:id="tableView"
                           styleClass="modern-table"
                           BorderPane.alignment="CENTER"
                           VBox.vgrow="ALWAYS"/>
            </children>
        </VBox>
    </center>

</BorderPane>