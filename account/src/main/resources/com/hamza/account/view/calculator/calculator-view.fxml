<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17"
      fx:controller="com.hamza.account.controller.calculator.CalculatorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TextField fx:id="display" alignment="CENTER_RIGHT" editable="false" style="-fx-font-size: 20px;"/>

    <GridPane alignment="CENTER" hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="50.0" prefWidth="50.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="50.0" prefWidth="50.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="50.0" prefWidth="50.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="50.0" prefWidth="50.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES"/>
        </rowConstraints>

        <!-- First Row -->
        <Button maxWidth="Infinity" maxHeight="Infinity" text="7" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="8" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="9" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="/" onMouseClicked="#handleOperatorAction"
                GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <!-- Second Row -->
        <Button maxWidth="Infinity" maxHeight="Infinity" text="4" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="5" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="6" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="*" onMouseClicked="#handleOperatorAction"
                GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <!-- Third Row -->
        <Button maxWidth="Infinity" maxHeight="Infinity" text="1" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="2" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="3" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="-" onMouseClicked="#handleOperatorAction"
                GridPane.columnIndex="3" GridPane.rowIndex="2"/>

        <!-- Fourth Row -->
        <Button maxWidth="Infinity" maxHeight="Infinity" text="0" onMouseClicked="#handleDigitAction"
                GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="." onMouseClicked="#handleDecimalAction"
                GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="C" onMouseClicked="#handleClearAction"
                GridPane.columnIndex="2" GridPane.rowIndex="3"/>
        <Button maxWidth="Infinity" maxHeight="Infinity" text="+" onMouseClicked="#handleOperatorAction"
                GridPane.columnIndex="3" GridPane.rowIndex="3"/>

        <!-- Fifth Row -->
        <Button maxWidth="Infinity" maxHeight="Infinity" text="=" onMouseClicked="#handleEqualsAction"
                GridPane.columnIndex="0" GridPane.columnSpan="4" GridPane.rowIndex="4"/>
    </GridPane>
</VBox>
