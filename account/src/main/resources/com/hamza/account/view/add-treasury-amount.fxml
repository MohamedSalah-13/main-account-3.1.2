<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <children>
                <VBox styleClass="dashboard-tile" VBox.vgrow="SOMETIMES">
                    <children>
                        <GridPane hgap="5.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"
                                                   prefWidth="250.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                            </rowConstraints>
                            <children>
                                <Label fx:id="labelCode" text="Code"/>
                                <Label fx:id="labelDate" text="Date" GridPane.rowIndex="1"/>
                                <Label fx:id="labelAmount" text="Amount" GridPane.rowIndex="2"/>
                                <Label fx:id="labelTreasury" text="Treasury" GridPane.rowIndex="3"/>
                                <TextField fx:id="txtCode" editable="false" GridPane.columnIndex="1"/>
                                <TextField fx:id="txtAmount" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <DatePicker fx:id="dateAdd" editable="false" maxWidth="1.7976931348623157E308"
                                            GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <ComboBox fx:id="comboTreasury" maxWidth="1.7976931348623157E308"
                                          GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                <Label fx:id="labelDescription" text="Notes" GridPane.rowIndex="4"/>
                                <TextArea fx:id="txtDescription" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            </children>
                        </GridPane>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </padding>
        </VBox>
    </children>
</AnchorPane>
