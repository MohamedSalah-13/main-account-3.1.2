<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="stackPane" minHeight="-Infinity" minWidth="-Infinity" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
      <BorderPane styleClass="app-container">
         <top>
                  <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-card" BorderPane.alignment="CENTER">
                      <children>
                          <Label fx:id="labelSearch" text="Search" />
                          <TextField fx:id="txtSearch" HBox.hgrow="SOMETIMES" />
                          <CheckBox fx:id="checkAddDirect" mnemonicParsing="false" text="إضافة مباشرة" />
                      </children>
                      <padding>
                          <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                      </padding>
                  </HBox>
         </top>
         <bottom>
                  <HBox alignment="CENTER_RIGHT" spacing="5.0" styleClass="pane-box-last" BorderPane.alignment="CENTER">
                      <children>
                          <Button fx:id="btnSave" mnemonicParsing="false" styleClass="app-neutral-button" text="Save" />
                          <Button fx:id="btnClose" layoutX="15.0" layoutY="16.0" mnemonicParsing="false" styleClass="app-danger-button" text="Close" />
                      </children>
                  </HBox>
         </bottom>
         <center>
            <ScrollPane fitToHeight="true" fitToWidth="true" BorderPane.alignment="CENTER">
               <content>
                    <SplitPane fx:id="splitPane" dividerPositions="0.5" orientation="VERTICAL">
                        <items>
                              <Pagination fx:id="pagination" minHeight="-Infinity" minWidth="-Infinity" prefHeight="250.0" prefWidth="500.0" />
                            <VBox>
                                <children>
                                    <ToolBar styleClass="search-card">
                                        <items>
                                            <Button fx:id="btnAdd2" mnemonicParsing="false" styleClass="app-neutral-button" text="إضافة" />
                                        </items>
                                    </ToolBar>
                                    <TableView fx:id="tableView" minHeight="-Infinity" minWidth="-Infinity" prefHeight="250.0" prefWidth="500.0" VBox.vgrow="SOMETIMES">
                        </TableView>
                                </children>
                                <padding>
                                    <Insets bottom="5.0" left="5.0" right="5.0" />
                                </padding>
                            </VBox>
                        </items>
                    </SplitPane>
               </content>
            </ScrollPane>
         </center>
      </BorderPane>
    </children>
</StackPane>
