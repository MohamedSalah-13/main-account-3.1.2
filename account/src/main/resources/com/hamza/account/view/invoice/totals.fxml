<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:id="stackPane" xmlns="http://javafx.com/javafx/21">
    <children>
        <VBox>
            <children>
                <ToolBar fx:id="toolBar">
                    <items>
                        <Button fx:id="btnUpdate" mnemonicParsing="false" text="Update"/>
                        <Button fx:id="btnDelete" mnemonicParsing="false" text="Delete"/>
                        <Button fx:id="btnRefresh" mnemonicParsing="false" text="Refresh"/>
                        <Separator orientation="VERTICAL"/>
                        <Button fx:id="btnShowInvoice" layoutX="131.0" layoutY="12.0" mnemonicParsing="false"
                                text="Show"/>
                        <Button fx:id="btnToExcel" layoutX="79.0" layoutY="12.0" mnemonicParsing="false"
                                text="Export Excel"/>
                        <ToggleButton fx:id="btnSelected" mnemonicParsing="false" text="Select All"/>
                        <MenuButton fx:id="menuButton" mnemonicParsing="false" styleClass="menu-button-items"
                                    text="طباعة">
                            <items>
                                <MenuItem fx:id="menuItemPrintTotals" mnemonicParsing="false" text="طباعة إجمالى"/>
                                <MenuItem fx:id="menuItemPrintDetailed" mnemonicParsing="false" text="طباعة تفصيلى"/>
                            </items>
                        </MenuButton>
                    </items>
                </ToolBar>
                <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="SOMETIMES">
                    <content>
                        <VBox spacing="5.0">
                            <children>
                                <VBox fx:id="box" spacing="5.0" styleClass="dashboard-tile">
                                    <children>
                                        <GridPane fx:id="gridPane" minHeight="-Infinity" minWidth="-Infinity"
                                                  styleClass="grid-pane-style">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                            </rowConstraints>
                                            <children>
                                                <Label fx:id="labelDelegate" text="Delegate" GridPane.columnIndex="2"
                                                       GridPane.rowIndex="1"/>
                                                <Label fx:id="labelName" text="Name" GridPane.rowIndex="1"/>
                                                <Label fx:id="labelFrom" text="From" GridPane.rowIndex="2"/>
                                                <Label fx:id="labelTo" text="To" GridPane.columnIndex="2"
                                                       GridPane.rowIndex="2"/>
                                                <DatePicker fx:id="dateFrom" editable="false"
                                                            maxWidth="1.7976931348623157E308" GridPane.columnIndex="1"
                                                            GridPane.rowIndex="2"/>
                                                <DatePicker fx:id="dateTo" editable="false"
                                                            maxWidth="1.7976931348623157E308" GridPane.columnIndex="3"
                                                            GridPane.rowIndex="2"/>
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="1"
                                                      GridPane.rowIndex="3">
                                                    <children>
                                                        <RadioButton fx:id="radioAll" mnemonicParsing="false"
                                                                     selected="true" text="الكل">
                                                            <toggleGroup>
                                                                <ToggleGroup fx:id="group"/>
                                                            </toggleGroup>
                                                        </RadioButton>
                                                        <RadioButton fx:id="radioCash" layoutX="10.0" layoutY="10.0"
                                                                     mnemonicParsing="false" text="نقدا"
                                                                     toggleGroup="$group"/>
                                                        <RadioButton fx:id="radioDeffer" layoutX="97.0" layoutY="10.0"
                                                                     mnemonicParsing="false" text="أجل"
                                                                     toggleGroup="$group"/>
                                                        <Button fx:id="btnSearch" minWidth="-Infinity"
                                                                mnemonicParsing="false" text="Search"/>
                                                    </children>
                                                </HBox>
                                                <Label fx:id="labelTextSearch" text="Search"/>
                                                <TextField fx:id="textSearch" promptText="Search"
                                                           GridPane.columnIndex="1"/>
                                                <CheckBox fx:id="checkBoxShowOtherSearch" minWidth="-Infinity"
                                                          mnemonicParsing="false" text="Show Other Search"
                                                          GridPane.columnIndex="3"/>
                                                <ComboBox fx:id="comboDelegate" GridPane.columnIndex="3"
                                                          GridPane.rowIndex="1"/>
                                                <ComboBox fx:id="comboName" GridPane.columnIndex="1"
                                                          GridPane.rowIndex="1"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>
                                <TableView fx:id="tableView" minHeight="-Infinity" VBox.vgrow="SOMETIMES">
                                </TableView>
                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="pane-box-last">
                                    <children>
                                        <Label fx:id="labelSumTableSize" text="Sum Table"/>
                                        <Text fx:id="textSumTableSize" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0"/>
                                        <Label fx:id="labelSumTotals" text="Totals"/>
                                        <Text fx:id="textSumTotals" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0"/>
                                        <Label fx:id="labelSumDiscount" text="Discount"/>
                                        <Text fx:id="textSumDiscount" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0"/>
                                        <Label fx:id="labelSumAfterDiscount" text="After Discount"/>
                                        <Text fx:id="textSumAfterDiscount" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0"/>
                                        <Label fx:id="labelSumAfterDiscount1" text="مدفوع"/>
                                        <Text fx:id="textCash" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0"/>
                                        <Label fx:id="labelSumAfterDiscount11" text="باقى"/>
                                        <Text fx:id="textDeffer" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0"/>
                                        <Label fx:id="labelSumAfterDiscount111" layoutX="389.0" layoutY="10.0"
                                               text="الربح"/>
                                        <Text fx:id="textProfit" layoutX="423.0" layoutY="24.0" strokeType="OUTSIDE"
                                              strokeWidth="0.0" styleClass="text-sum" text="0"/>
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</StackPane>
