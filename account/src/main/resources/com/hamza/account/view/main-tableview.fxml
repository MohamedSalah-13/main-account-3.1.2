<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane fx:id="root"
           minHeight="400.0"
           minWidth="700.0"
           prefHeight="472.0"
           prefWidth="750.0"
           nodeOrientation="RIGHT_TO_LEFT"
           styleClass="table-screen-root"
           stylesheets="@../css/table-modern.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox spacing="14.0" styleClass="table-screen-container">
            <children>
                <ToolBar fx:id="toolBar" styleClass="modern-toolbar">
                    <items>
                        <Button fx:id="btnNew"
                                mnemonicParsing="false"
                                text="new"
                                styleClass="success-action-button"/>

                        <Button fx:id="btnUpdate"
                                mnemonicParsing="false"
                                text="update"
                                styleClass="warning-action-button"/>

                        <Button fx:id="btnDelete"
                                mnemonicParsing="false"
                                text="delete"
                                styleClass="danger-action-button"/>

                        <Separator orientation="VERTICAL" styleClass="modern-separator"/>

                        <Button fx:id="btnRefresh"
                                mnemonicParsing="false"
                                text="refresh"
                                styleClass="neutral-action-button"/>

                        <Button fx:id="btnPrint"
                                mnemonicParsing="false"
                                text="print"
                                styleClass="primary-action-button"/>

                        <ToggleButton fx:id="btnSelected"
                                      mnemonicParsing="false"
                                      text="select/deselect"
                                      styleClass="select-action-toggle"/>
                    </items>
                </ToolBar>

                <ScrollPane fitToHeight="true"
                            fitToWidth="true"
                            styleClass="modern-scroll-pane"
                            VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="14.0">
                            <children>
                                <VBox fx:id="boxCenter"
                                      spacing="10.0"
                                      styleClass="search-card">
                                    <children>
                                        <GridPane fx:id="gridPane"
                                                  hgap="12.0"
                                                  vgap="10.0"
                                                  minHeight="-Infinity"
                                                  minWidth="-Infinity">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="90.0"/>
                                                <ColumnConstraints minWidth="260.0" hgrow="ALWAYS"/>
                                            </columnConstraints>

                                            <rowConstraints>
                                                <RowConstraints minHeight="40.0" prefHeight="40.0"/>
                                            </rowConstraints>

                                            <children>
                                                <Label fx:id="labelSearch"
                                                       text="Search"
                                                       styleClass="form-label"/>

                                                <TextField fx:id="txtSearch"
                                                           focusTraversable="false"
                                                           promptText="اكتب للبحث..."
                                                           styleClass="modern-input"
                                                           GridPane.columnIndex="1"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <Pagination fx:id="pagination"
                                            styleClass="modern-pagination"
                                            VBox.vgrow="ALWAYS"/>

                                <HBox fx:id="hBox"
                                      alignment="CENTER_LEFT"
                                      spacing="8.0"
                                      styleClass="summary-bar">
                                    <children>
                                        <Label fx:id="labelSum"
                                               text="Sum"
                                               styleClass="summary-label"/>

                                        <Text fx:id="textSum"
                                              strokeType="OUTSIDE"
                                              strokeWidth="0.0"
                                              text="Text"
                                              styleClass="summary-value"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</StackPane>