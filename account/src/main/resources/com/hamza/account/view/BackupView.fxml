<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="18.0"
      nodeOrientation="RIGHT_TO_LEFT"
      styleClass="backup-root"
      stylesheets="@../css/reports-modern.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hamza.account.backup.BackupController">

    <padding>
        <Insets topRightBottomLeft="28"/>
    </padding>

    <VBox alignment="CENTER" spacing="18.0" styleClass="backup-card">
        <children>
            <VBox alignment="CENTER" spacing="5.0">
                <children>
                    <Label text="إدارة النسخ الاحتياطي" styleClass="report-title"/>
                    <Label text="إنشاء واستعادة النسخ الاحتياطية وجدولة النسخ التلقائي"
                           styleClass="report-subtitle"/>
                </children>
            </VBox>

            <GridPane hgap="12.0" vgap="18.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="140.0"/>
                    <ColumnConstraints minWidth="360.0" hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="110.0"/>
                </columnConstraints>

                <rowConstraints>
                    <RowConstraints minHeight="42.0"/>
                    <RowConstraints minHeight="42.0"/>
                    <RowConstraints minHeight="42.0"/>
                </rowConstraints>

                <children>
                    <Label text="مسار الحفظ:" styleClass="form-label"/>
                    <TextField fx:id="backupPathField"
                               editable="false"
                               styleClass="modern-input"
                               GridPane.columnIndex="1"/>
                    <Button onAction="#changeBackupPath"
                            text="تغيير"
                            styleClass="neutral-button"
                            GridPane.columnIndex="2"/>

                    <Label text="كلمة مرور التشفير:"
                           styleClass="form-label"
                           GridPane.rowIndex="1"/>
                    <PasswordField fx:id="encryptionPasswordField"
                                   promptText="كلمة مرور لحماية النسخة"
                                   styleClass="modern-input"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>

                    <Label text="التكرار التلقائي:"
                           styleClass="form-label"
                           GridPane.rowIndex="2"/>
                    <ComboBox fx:id="intervalCombo"
                              maxWidth="1.7976931348623157E308"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="2"/>
                    <Button onAction="#applySchedule"
                            text="تطبيق"
                            styleClass="primary-button"
                            GridPane.columnIndex="2"
                            GridPane.rowIndex="2"/>
                </children>
            </GridPane>

            <HBox alignment="CENTER" spacing="14.0">
                <children>
                    <Button fx:id="backupBtn"
                            onAction="#backupNow"
                            styleClass="success-button"
                            text="نسخ احتياطي الآن"/>

                    <Button fx:id="restoreBtn"
                            onAction="#restoreBackup"
                            styleClass="warning-button"
                            text="استعادة نسخة"/>
                </children>
            </HBox>

            <HBox fx:id="progressBox" alignment="CENTER" spacing="10.0" visible="false">
                <children>
                    <ProgressIndicator fx:id="progressIndicator"
                                       maxHeight="30.0"
                                       maxWidth="30.0"/>
                    <Label fx:id="progressLabel"
                           styleClass="status-label"
                           text="جارٍ النسخ الاحتياطي..."/>
                </children>
            </HBox>

            <Label fx:id="statusLabel" styleClass="status-label" text="جاهز"/>
        </children>
    </VBox>
</VBox>