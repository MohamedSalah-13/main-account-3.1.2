<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <VBox fx:id="box" prefHeight="400.0" prefWidth="600.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox spacing="5.0" VBox.vgrow="SOMETIMES">
                    <children>
                        <VBox styleClass="dashboard-tile">
                            <children>
                                <GridPane minHeight="-Infinity" minWidth="-Infinity" styleClass="grid-pane-style">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"
                                                           prefWidth="100.0"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                    </rowConstraints>
                                    <children>
                                        <Label text="البيان" GridPane.rowIndex="1"/>
                                        <Label text="الخزينة" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                        <Label text="المبلغ" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                                        <TextField fx:id="txtStatement" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                        <TextField fx:id="txtAmount" GridPane.columnIndex="5" GridPane.rowIndex="1"/>
                                        <ComboBox fx:id="comboTreasury" maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                                        <Label text="ملاحظات" GridPane.rowIndex="2"/>
                                        <TextArea fx:id="txtDescription" GridPane.columnIndex="1"
                                                  GridPane.rowIndex="2"/>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="3"
                                              GridPane.rowIndex="2">
                                            <children>
                                                <RadioButton fx:id="radioDeposit" layoutX="10.0" layoutY="10.0"
                                                             mnemonicParsing="false" selected="true" text="إيداع">
                                                    <toggleGroup>
                                                        <ToggleGroup fx:id="group"/>
                                                    </toggleGroup>
                                                </RadioButton>
                                                <RadioButton fx:id="radioWithdraw" mnemonicParsing="false" text="سحب"
                                                             toggleGroup="$group"/>
                                                <Button fx:id="btnPrintTreasuryDisclosure" mnemonicParsing="false"
                                                        text="كشف الخزينة"/>
                                            </children>
                                        </HBox>
                                        <Label text="العملية" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                        <Label text="كود"/>
                                        <Label text="التاريخ" GridPane.columnIndex="2"/>
                                        <TextField fx:id="txtCode" GridPane.columnIndex="1"/>
                                        <DatePicker fx:id="dateAdd" editable="false" maxWidth="1.7976931348623157E308"
                                                    GridPane.columnIndex="3"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                        <TableView fx:id="tableView" VBox.vgrow="SOMETIMES"/>
                    </children>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </padding>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
