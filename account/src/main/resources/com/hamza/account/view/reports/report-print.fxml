<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.SearchableComboBox?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:id="stackPane" xmlns="http://javafx.com/javafx/21">
    <children>
        <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="SOMETIMES">
            <content>
                <VBox fx:id="root" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <VBox spacing="5.0" VBox.vgrow="SOMETIMES">
                            <children>
                                <VBox minHeight="-Infinity" spacing="5.0" styleClass="dashboard-tile">
                                    <children>
                                        <GridPane minHeight="-Infinity" minWidth="-Infinity"
                                                  styleClass="grid-pane-style">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                            </rowConstraints>
                                            <children>
                                                <Label fx:id="labelFrom" text="From" GridPane.rowIndex="1"/>
                                                <DatePicker fx:id="dateFrom" editable="false"
                                                            maxWidth="1.7976931348623157E308" GridPane.columnIndex="1"
                                                            GridPane.rowIndex="1"/>
                                                <Label fx:id="labelTo" text="To" GridPane.columnIndex="2"
                                                       GridPane.rowIndex="1"/>
                                                <DatePicker fx:id="dateTo" editable="false"
                                                            maxWidth="1.7976931348623157E308" GridPane.columnIndex="3"
                                                            GridPane.rowIndex="1"/>
                                                <Button fx:id="btnSearchName" mnemonicParsing="false" text="Search"
                                                        GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                                                <Label fx:id="labelName" text="Name"/>
                                                <CheckBox fx:id="checkExpanded" mnemonicParsing="false" text="Expanded"
                                                          GridPane.columnIndex="4"/>
                                                <Label text="العملية" GridPane.columnIndex="2"/>
                                                <SearchableComboBox fx:id="comboName" GridPane.columnIndex="1"/>
                                                <SearchableComboBox fx:id="comboDetails" GridPane.columnIndex="3"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                    <padding>
                                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                    </padding>
                                </VBox>
                                <TreeTableView fx:id="treeView" styleClass="table-view" VBox.vgrow="SOMETIMES">
                                    <columns>
                                        <TreeTableColumn prefWidth="75.0" text="C1"/>
                                        <TreeTableColumn prefWidth="75.0" text="C2"/>
                                    </columns>
                                </TreeTableView>
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                            </padding>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</StackPane>
