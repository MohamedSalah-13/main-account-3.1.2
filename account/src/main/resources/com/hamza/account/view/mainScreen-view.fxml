<?import javafx.scene.control.Separator?>
<BorderPane fx:id="borderPane" minHeight="600.0" minWidth="850.0" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <center>
            <TabPane fx:id="tabPane" styleClass="main-tab-pane" tabClosingPolicy="ALL_TABS">
                <tabs>
                    <Tab text="الرئيسية">
                        <content>
                            <AnchorPane>
                                <children>
                        <VBox layoutX="5.0" layoutY="5.0" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
                           <children>
                              <VBox fx:id="box" VBox.vgrow="SOMETIMES" />
                              <HBox>
                                 <children>
                                    <Button fx:id="btnYouTube" mnemonicParsing="false" styleClass="danger-button" text="YouTube" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                                </children>
                            </AnchorPane>
                        </content>

                                    <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@../image/icons8-home-page-80.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Tab>
                </tabs>
            </TabPane>
    </center>
   <left>
      <AnchorPane minWidth="-Infinity" prefWidth="230.0" styleClass="right-pane-root" BorderPane.alignment="CENTER">
         <children>
            <VBox prefHeight="600.0" prefWidth="200.0" spacing="5.0" styleClass="right-pane-container" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <MenuButton fx:id="menuButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="modern-menu-button" text="MenuButton">
                     <items>
                        <MenuItem fx:id="menuItemChangeName" mnemonicParsing="false" text="Change Name" />
                        <MenuItem fx:id="menuItemChangePass" mnemonicParsing="false" text="Change Password" />
                        <MenuItem fx:id="menuItemLogout" mnemonicParsing="false" text="Logout" />
                     </items>
                  </MenuButton>
                  <Accordion styleClass="main-accordion">
                     <panes>
                        <TitledPane fx:id="paneSales" animated="false" text="Sales">
                           <content>
                              <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                 <content>
                                    <VBox styleClass="side-button-box">
                                       <children>
                                          <Button fx:id="btnSales" mnemonicParsing="false" text="Sales" />
                                          <Button fx:id="btnTotalSale" mnemonicParsing="false" text="Total Sales" />
                                          <Button fx:id="btnTotalSales" mnemonicParsing="false" text="Total Sales" />
                                          <Button fx:id="btnTotalSalesRe" mnemonicParsing="false" text="Total Sales Re" />
                                       </children>
                                    </VBox>
                                 </content>
                              </ScrollPane>
                           </content>
                        </TitledPane>
                        <TitledPane fx:id="panePurchase" animated="false" text="Purchase">
                           <content>
                              <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                 <content>
                                    <VBox styleClass="side-button-box">
                                       <children>
                                          <Button fx:id="btnPurchase" mnemonicParsing="false" text="Purchase" />
                                          <Button fx:id="btnPurchaseRe" mnemonicParsing="false" text="Purchase Re" />
                                          <Button fx:id="btnTotalPurchase" mnemonicParsing="false" text="Total Purchase" />
                                          <Button fx:id="btnTotalPurchaseRe" mnemonicParsing="false" text="Total Purchase Re" />
                                       </children>
                                    </VBox>
                                 </content>
                              </ScrollPane>
                           </content>
                        </TitledPane>
                        <TitledPane fx:id="paneItems" animated="false" text="Items">
                           <content>
                              <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                 <content>
                                    <VBox styleClass="side-button-box">
                                       <children>
                                          <Button fx:id="btnItems" mnemonicParsing="false" text="Items" />
                                          <Button fx:id="btnAddItem" mnemonicParsing="false" text="Add Item" />
                                          <Button fx:id="btnItemFromExcel" mnemonicParsing="false" text="Import Items" />
                                          <Button fx:id="btnUnits" mnemonicParsing="false" text="Units" />
                                          <Button fx:id="btnMainGroup" mnemonicParsing="false" text="Main Group" />
                                          <Button fx:id="btnSupGroup" mnemonicParsing="false" text="Sup Group" />
                                          <Button fx:id="btnConvertStock" mnemonicParsing="false" text="Transfer Stocks" />
                                          <Button fx:id="btnInventory" mnemonicParsing="false" text="Inventory" />
                                       </children>
                                    </VBox>
                                 </content>
                              </ScrollPane>
                           </content>
                        </TitledPane>
                        <TitledPane fx:id="paneCustom" animated="false" text="Custom">
                           <content>
                              <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                 <content>
                                    <VBox styleClass="side-button-box">
                                       <children>
                                          <Button fx:id="btnAddCustomer" mnemonicParsing="false" text="Add Customer" />
                                          <Button fx:id="btnCustomer" mnemonicParsing="false" text="Customer" />
                                          <Button fx:id="btnAccountCustom" mnemonicParsing="false" text="Account Customer" />
                                       </children>
                                    </VBox>
                                 </content>
                              </ScrollPane>
                           </content>
                        </TitledPane>
                        <TitledPane fx:id="paneSuppliers" animated="false" text="Suppliers">
                           <content>
                              <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                 <content>
                                    <VBox styleClass="side-button-box">
                                       <children>
                                          <Button fx:id="btnAddSuppliers" mnemonicParsing="false" text="Add Suppliers" />
                                          <Button fx:id="btnSuppliers" mnemonicParsing="false" text="Suppliers" />
                                          <Button fx:id="btnAccountSuppliers" mnemonicParsing="false" text="Account Suppliers" />
                                       </children>
                                    </VBox>
                                 </content>
                              </ScrollPane>
                           </content>
                        </TitledPane>
                        <TitledPane fx:id="paneReports" animated="false" text="Reports">
                           <content>
                              <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                 <content>
                                    <VBox styleClass="side-button-box">
                                       <children>
                                          <Button fx:id="btnItemSummary" mnemonicParsing="false" text="Summary" />
                                       </children>
                                    </VBox>
                                 </content>
                              </ScrollPane>
                           </content>
                        </TitledPane>
                        <TitledPane fx:id="paneTreasury" animated="false" text="Treasury">
                           <content>
                              <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                 <content>
                                    <VBox styleClass="side-button-box">
                                       <children>
                                          <Button fx:id="btnTreasuryDetails" mnemonicParsing="false" text="كشف حساب" />
