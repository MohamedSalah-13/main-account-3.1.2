<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane fx:id="stackPane" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
      <BorderPane styleClass="app-container">
         <top>
                  <ToolBar BorderPane.alignment="CENTER">
                      <items>
                          <Button fx:id="btnNew" mnemonicParsing="false" styleClass="app-neutral-button" text="جديد" />
                          <Button fx:id="btnRefresh" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" styleClass="app-neutral-button" text="تحديث" />
                          <Button fx:id="btnPrint" layoutX="84.0" layoutY="10.0" mnemonicParsing="false" styleClass="app-neutral-button" text="طباعة" />
                          <Separator orientation="VERTICAL" />
                          <Button fx:id="btnExport" layoutX="158.0" layoutY="10.0" mnemonicParsing="false" styleClass="pdf-button" text="تصدير" />
                          <ToggleButton fx:id="btnSelected" mnemonicParsing="false" styleClass="app-neutral-button" text="تحديد الكل" />
                          <Button fx:id="btnShow" layoutX="107.0" layoutY="10.0" mnemonicParsing="false" styleClass="app-primary-button" text="كشف حساب" />
                          <Button fx:id="btnPaidAll" layoutX="158.0" layoutY="10.0" mnemonicParsing="false" styleClass="app-primary-button" text="المدفوعات" />
                      </items>
                  </ToolBar>
         </top>
         <bottom>
                      <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="summary-card" BorderPane.alignment="CENTER">
                          <children>
                              <Label text="عدد" />
                              <Text fx:id="textCount" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-sum" text="0.0" />
                              <Label layoutX="10.0" layoutY="10.0" text="مدين" />
                              <Text fx:id="textTotalPurchase" layoutX="38.0" layoutY="23.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-sum" text="0.0" />
                              <Label layoutX="38.0" layoutY="10.0" text="دائن" />
                              <Text fx:id="textTotalPaid" layoutX="145.0" layoutY="23.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-sum" text="0.0" />
                              <Label layoutX="10.0" layoutY="10.0" text="الباقى" />
                              <Text fx:id="textTotalRest" layoutX="168.0" layoutY="23.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-sum" text="0.0" />
                          </children>
                      </HBox>
         </bottom>
         <center>
                  <ScrollPane fitToHeight="true" fitToWidth="true" BorderPane.alignment="CENTER">
                      <content>
                          <VBox spacing="5.0">
                              <children>
                                  <VBox fx:id="box" spacing="5.0">
                                      <children>
                              <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="search-card">
                                 <children>
                                                  <Label styleClass="form-label" text="بحث" />
                                                  <TextField fx:id="textSearch" promptText="بحث" HBox.hgrow="SOMETIMES" />
                                                    <CheckBox fx:id="checkByZero" mnemonicParsing="false" text="إظهار الرصيد صفر" />
                                 </children>
                              </HBox>
                                      </children>
                                  </VBox>
                                    <TableView fx:id="tableView" styleClass="app-table" VBox.vgrow="SOMETIMES" />
                              </children>
                          </VBox>
                      </content>
                  </ScrollPane>
         </center>
      </BorderPane>
    </children>
</StackPane>
