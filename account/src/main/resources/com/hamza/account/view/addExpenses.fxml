<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox layoutX="5.0" layoutY="5.0" styleClass="dashboard-tile" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <children>
                <GridPane hgap="10.0" styleClass="app-card" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label fx:id="labelCode" text="Code" />
                        <Label fx:id="labelDate" text="Date" GridPane.rowIndex="1" />
                        <Label fx:id="labelType" text="Type" GridPane.rowIndex="2" />
                        <Label fx:id="labelName" text="Name Employee" GridPane.rowIndex="3" />
                        <Label fx:id="labelAmount" text="Amount" GridPane.rowIndex="4" />
                        <Label fx:id="labelNotes" text="Notes" GridPane.rowIndex="5" />
                        <TextField fx:id="txtCode" editable="false" promptText="code" GridPane.columnIndex="1" />
                        <TextField fx:id="txtAmount" maxWidth="1.7976931348623157E308" promptText="amount" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <DatePicker fx:id="date" editable="false" maxWidth="1.7976931348623157E308" promptText="date" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <ComboBox fx:id="comboType" maxWidth="1.7976931348623157E308" promptText="type" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <ComboBox fx:id="comboName" maxWidth="1.7976931348623157E308" promptText="name emplyee" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <TextArea fx:id="txtNotes" promptText="notes" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    </children>
                </GridPane>
            </children>
        </VBox>
