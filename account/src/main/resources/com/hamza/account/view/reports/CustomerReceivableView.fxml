<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hamza.account.controller.reports.CustomerReceivableController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f4f4f4; -fx-padding: 10;">
                    <children>
                        <Label text="تقرير أرصدة العملاء (الديون المستحقة)" textFill="#c0392b">
                            <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#refreshData" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="تحديث البيانات" />
                        <Button onAction="#onExportPdf" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="PDF" />
                        <Button onAction="#onExportExcel" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Excel" />
                    </children>
                </HBox>

                <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="250.0" text="اسم العميل" />
                        <TableColumn fx:id="colPhone" prefWidth="150.0" text="رقم الهاتف" />
                        <TableColumn fx:id="colInvoices" prefWidth="150.0" text="ديون الفواتير" />
                        <TableColumn fx:id="colOpening" prefWidth="150.0" text="مديونية سابقة" />
                        <TableColumn fx:id="colTotal" prefWidth="150.0" text="إجمالي المستحق" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" style="-fx-background-color: #2c3e50; -fx-padding: 10;">
                    <children>
                        <Label text="إجمالي ديون العملاء طرفكم: " textFill="WHITE">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Label fx:id="lblGrandTotal" text="0.00" textFill="#f1c40f">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>