<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0"
            prefWidth="900.0"
            nodeOrientation="RIGHT_TO_LEFT"
            styleClass="app-root"

            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hamza.account.controller.reports.CustomerReceivableController">
    <children>
        <VBox spacing="16.0"
              styleClass="app-container"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="app-card">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="تقرير أرصدة العملاء" styleClass="report-title"/>
                                <Label text="الديون والمبالغ المستحقة على العملاء" styleClass="report-subtitle"/>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button onAction="#refreshData" text="تحديث البيانات" styleClass="neutral-button"/>
                        <Button onAction="#onExportPdf" text="PDF" styleClass="pdf-button"/>
                        <Button onAction="#onExportExcel" text="Excel" styleClass="excel-button"/>
                    </children>
                </HBox>

                <TableView fx:id="tableView" styleClass="app-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="250.0" text="اسم العميل"/>
                        <TableColumn fx:id="colPhone" prefWidth="150.0" text="رقم الهاتف"/>
                        <TableColumn fx:id="colInvoices" prefWidth="150.0" text="ديون الفواتير"/>
                        <TableColumn fx:id="colOpening" prefWidth="150.0" text="مديونية سابقة"/>
                        <TableColumn fx:id="colTotal" prefWidth="150.0" text="إجمالي المستحق"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="8.0" styleClass="summary-card">
                    <children>
                        <Label text="إجمالي ديون العملاء طرفكم:" styleClass="summary-label"/>
                        <Label fx:id="lblGrandTotal" text="0.00" styleClass="summary-value"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>