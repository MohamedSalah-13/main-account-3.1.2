<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="stackPane" prefHeight="484.0" prefWidth="616.0" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox spacing="5.0" styleClass="app-container">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="app-card">
                    <children>
                          <Label fx:id="labelSearch" text="Search" />
                          <TextField fx:id="txtSearch" styleClass="text-field" HBox.hgrow="SOMETIMES" />
                    </children>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                    </padding>
                </HBox>
                <TableView fx:id="tableView" styleClass="app-table" VBox.vgrow="SOMETIMES" />
            </children>
        </VBox>
    </children>
</StackPane>
