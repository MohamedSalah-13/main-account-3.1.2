<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:id="stackPane" xmlns="http://javafx.com/javafx/21">
    <children>
        <ScrollPane fitToHeight="true" fitToWidth="true">
            <content>
                <VBox spacing="5.0">
                    <children>
                        <VBox>
                            <children>
                                <HBox alignment="CENTER" spacing="5.0" styleClass="box-title">
                                    <children>
                                        <Label fx:id="textStart" text="Label"/>
                                    </children>
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                                    </padding>
                                </HBox>
                                <VBox styleClass="dashboard-tile">
                                    <children>
                                        <GridPane minHeight="-Infinity" minWidth="-Infinity"
                                                  styleClass="grid-pane-style">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                            </rowConstraints>
                                            <children>
                                                <Label fx:id="labelYear" text="Year"/>
                                                <ComboBox fx:id="comboBox" prefWidth="300.0" GridPane.columnIndex="1"/>
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="1"
                                                      GridPane.rowIndex="1">
                                                    <children>
                                                        <RadioButton fx:id="radioYear" mnemonicParsing="false"
                                                                     selected="true" text="Year">
                                                            <toggleGroup>
                                                                <ToggleGroup fx:id="group"/>
                                                            </toggleGroup>
                                                        </RadioButton>
                                                        <RadioButton fx:id="radioMonth" layoutX="10.0" layoutY="10.0"
                                                                     mnemonicParsing="false" text="Month"
                                                                     toggleGroup="$group"/>
                                                        <Button fx:id="btnSearch" mnemonicParsing="false"
                                                                text="Search"/>
                                                        <Button fx:id="btnPrint" mnemonicParsing="false" text="Print"/>
                                                    </children>
                                                    <padding>
                                                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                                    </padding>
                                                </HBox>
                                                <CheckBox fx:id="checkZeroData" mnemonicParsing="false"
                                                          text="Show Zero Data" GridPane.columnIndex="2"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                        <TableView fx:id="tableView" VBox.vgrow="SOMETIMES">
                            <columns>
                                <TableColumn prefWidth="75.0" text="C1"/>
                                <TableColumn prefWidth="75.0" text="C2"/>
                            </columns>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</StackPane>
