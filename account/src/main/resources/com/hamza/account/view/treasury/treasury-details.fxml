<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:id="stackPane" xmlns="http://javafx.com/javafx/21">
    <children>
        <AnchorPane>
            <children>
                <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                      AnchorPane.topAnchor="0.0">
                    <children>
                        <ToolBar prefHeight="40.0" prefWidth="200.0">
                            <items>
                                <Button fx:id="btnRefresh" mnemonicParsing="false" text="تحديث"/>
                                <Button fx:id="btnPrint" mnemonicParsing="false" text="طباعة"/>
                                <Button fx:id="btnPrintSummary" mnemonicParsing="false" text="ملخص الوردية"/>
                            </items>
                        </ToolBar>
                        <VBox spacing="5.0" VBox.vgrow="SOMETIMES">
                            <children>
                                <VBox minHeight="-Infinity" spacing="5.0" styleClass="dashboard-tile">
                                    <children>
                                        <GridPane fx:id="gridPane" minHeight="-Infinity" minWidth="-Infinity"
                                                  styleClass="grid-pane-style">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                            </rowConstraints>
                                            <children>
                                                <Label text="الخزينة"/>
                                                <Label text="من تاريخ" GridPane.rowIndex="2"/>
                                                <Label text="إلى تاريخ" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                                <ComboBox fx:id="comboTreasury" maxWidth="1.7976931348623157E308"
                                                          GridPane.columnIndex="1"/>
                                                <DatePicker fx:id="dateFrom" maxWidth="1.7976931348623157E308"
                                                            GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                                <DatePicker fx:id="dateTo" maxWidth="1.7976931348623157E308"
                                                            GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                                                <Label text="نوع الحساب" GridPane.columnIndex="2"/>
                                                <ComboBox fx:id="comboDetails" maxWidth="1.7976931348623157E308"
                                                          GridPane.columnIndex="3"/>
                                                <ComboBox fx:id="comboUsers" maxWidth="1.7976931348623157E308"
                                                          GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                                <Label text="المستخدم" GridPane.rowIndex="1"/>
                                                <Button fx:id="btnSearch" mnemonicParsing="false" text="بحث"
                                                        GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                                                <CheckBox fx:id="checkTime" mnemonicParsing="false" text="إضافة وقت"
                                                          GridPane.rowIndex="3"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>
                                <TableView fx:id="tableView" VBox.vgrow="SOMETIMES"/>
                                <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="pane-box-last">
                                    <children>
                                        <Label text="إجمالى الوارد"/>
                                        <Text fx:id="sumIncome" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0.0"/>
                                        <Label text="إجمالى الصادر"/>
                                        <Text fx:id="sumOutput" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0.0"/>
                                        <Label text="الرصيد"/>
                                        <Text fx:id="sumBalance" strokeType="OUTSIDE" strokeWidth="0.0"
                                              styleClass="text-sum" text="0.0"/>
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                            </padding>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</StackPane>
