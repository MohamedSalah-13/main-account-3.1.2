<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <HBox styleClass="dashboard-tile" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                    <children>
                        <GridPane styleClass="grid-pane-style">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES"/>
                            </rowConstraints>
                            <children>
                                <Label fx:id="labelCode" text="Code"/>
                                <Label fx:id="labelName" text="Name" GridPane.rowIndex="1"/>
                                <Label fx:id="labelBirthDate" text="BirthDate" GridPane.rowIndex="2"/>
                                <Label fx:id="labelHireDate" text="HireDate" GridPane.rowIndex="3"/>
                                <Label fx:id="labelSalary" text="Salary" GridPane.rowIndex="5"/>
                                <Label fx:id="labelTel" text="Tel" GridPane.rowIndex="4"/>
                                <Label fx:id="labelJop" text="Job" GridPane.rowIndex="6"/>
                                <Label fx:id="labelEmail" text="Email" GridPane.rowIndex="7"/>
                                <Label fx:id="labelAddress" text="Address" GridPane.rowIndex="8"/>
                                <TextField fx:id="txtCode" editable="false" GridPane.columnIndex="1"/>
                                <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <TextField fx:id="txtSalary" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                                <TextField fx:id="txtTel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                <ComboBox fx:id="comboJob" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1"
                                          GridPane.rowIndex="6"/>
                                <TextField fx:id="txtEmail" minWidth="-Infinity" prefWidth="210.0"
                                           GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                                <TextArea fx:id="textAreaAddress" minWidth="-Infinity" prefWidth="210.0"
                                          GridPane.columnIndex="1" GridPane.rowIndex="8"/>
                                <DatePicker fx:id="birthDate" editable="false" maxWidth="1.7976931348623157E308"
                                            GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <DatePicker fx:id="hireDate" editable="false" maxWidth="1.7976931348623157E308"
                                            GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                            </children>
                        </GridPane>
                    </children>
                </VBox>
                <VBox fx:id="boxImage" alignment="TOP_CENTER" spacing="5.0">
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </padding>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
