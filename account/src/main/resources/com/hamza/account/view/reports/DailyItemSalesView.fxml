<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hamza.account.controller.reports.DailyItemSalesController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-background-radius: 5;">
                    <children>
                        <Label text="تقرير حركة مبيعات الأصناف اليومي" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>

                        <Region HBox.hgrow="ALWAYS" /> <Label text="اختر التاريخ:">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Label>
                        <DatePicker fx:id="datePicker" prefWidth="150.0" />

                        <Button mnemonicParsing="false" onAction="#onSearchAction" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="بحث وعرض">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>

                        <Region prefWidth="20.0" />

                        <Button mnemonicParsing="false" onAction="#onExportPdf" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="تصدير PDF">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#onExportExcel" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="تصدير Excel">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                    </children>
                </HBox>

                <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colItemName" prefWidth="250.0" text="اسم الصنف" />
                        <TableColumn fx:id="colPrice" prefWidth="100.0" text="السعر" />
                        <TableColumn fx:id="colQuantity" prefWidth="100.0" text="الكمية المباعة" />
                        <TableColumn fx:id="colTotal" prefWidth="120.0" text="إجمالي المبيعات" />
<!--                        <TableColumn fx:id="colInvoiceNum" prefWidth="150.0" text="رقم الفاتورة" />-->
<!--                        <TableColumn fx:id="colTime" prefWidth="120.0" text="وقت البيع" />-->
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #fdfae6; -fx-border-color: #e6ce8a; -fx-border-width: 1; -fx-padding: 10; -fx-background-radius: 5;">
                    <children>
                        <Label text="إجمالي مبيعات اليوم المحددة:" textFill="#5e5022">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblDayTotal" text="0.00" textFill="#d35400">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>