<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0"
            prefWidth="1000.0"
            nodeOrientation="RIGHT_TO_LEFT"
            styleClass="app-root"

            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hamza.account.controller.reports.DailyItemSalesController">
    <children>
        <VBox spacing="16.0"
              styleClass="app-container"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="app-card">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="تقرير حركة مبيعات الأصناف اليومي" styleClass="report-title"/>
                                <Label text="عرض مبيعات الأصناف حسب يوم محدد" styleClass="report-subtitle"/>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="اختر التاريخ:" styleClass="form-label"/>
                        <DatePicker fx:id="datePicker" prefWidth="150.0"/>

                        <Button mnemonicParsing="false"
                                onAction="#onSearchAction"
                                text="بحث وعرض"
                                styleClass="primary-button"/>

                        <Button mnemonicParsing="false"
                                onAction="#onExportPdf"
                                text="تصدير PDF"
                                styleClass="pdf-button"/>

                        <Button mnemonicParsing="false"
                                onAction="#onExportExcel"
                                text="تصدير Excel"
                                styleClass="excel-button"/>
                    </children>
                </HBox>

                <TableView fx:id="tableView" styleClass="app-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colItemName" prefWidth="250.0" text="اسم الصنف"/>
                        <TableColumn fx:id="colPrice" prefWidth="100.0" text="السعر"/>
                        <TableColumn fx:id="colQuantity" prefWidth="100.0" text="الكمية المباعة"/>
                        <TableColumn fx:id="colTotal" prefWidth="120.0" text="إجمالي المبيعات"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="summary-light-card">
                    <children>
                        <Label text="إجمالي مبيعات اليوم المحددة:" styleClass="summary-light-label"/>
                        <Label fx:id="lblDayTotal" text="0.00" styleClass="summary-value danger-value"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>