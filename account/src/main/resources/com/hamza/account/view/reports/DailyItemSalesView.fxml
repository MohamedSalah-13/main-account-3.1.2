<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane nodeOrientation="RIGHT_TO_LEFT" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hamza.account.controller.reports.DailyItemSalesController">
    <children>
      <BorderPane styleClass="app-container" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="app-card" BorderPane.alignment="CENTER">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="report-title" text="تقرير حركة مبيعات الأصناف اليومي" />
                                <Label styleClass="report-subtitle" text="عرض مبيعات الأصناف حسب يوم محدد" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Label styleClass="form-label" text="اختر التاريخ:" />
                        <DatePicker fx:id="datePicker" prefWidth="150.0" />

                        <Button mnemonicParsing="false" onAction="#onSearchAction" styleClass="primary-button" text="بحث وعرض" />

                        <Button mnemonicParsing="false" onAction="#onExportPdf" styleClass="pdf-button" text="تصدير PDF" />

                        <Button mnemonicParsing="false" onAction="#onExportExcel" styleClass="excel-button" text="تصدير Excel" />
                    </children>
                </HBox>
         </top>
         <bottom>

                <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="summary-light-card" BorderPane.alignment="CENTER">
                    <children>
                        <Label styleClass="summary-light-label" text="إجمالي مبيعات اليوم المحددة:" />
                        <Label fx:id="lblDayTotal" styleClass="summary-value danger-value" text="0.00" />
                    </children>
                </HBox>
         </bottom>
         <center>
              <VBox spacing="5.0" styleClass="app-container" BorderPane.alignment="CENTER">
                  <children>
      
                      <TableView fx:id="tableView" minHeight="-Infinity" minWidth="-Infinity" prefHeight="250.0" styleClass="app-table" VBox.vgrow="ALWAYS">
                          <columns>
                              <TableColumn fx:id="colItemName" prefWidth="250.0" text="اسم الصنف" />
                              <TableColumn fx:id="colPrice" prefWidth="100.0" text="السعر" />
                              <TableColumn fx:id="colQuantity" prefWidth="100.0" text="الكمية المباعة" />
                              <TableColumn fx:id="colTotal" prefWidth="120.0" text="إجمالي المبيعات" />
                          </columns>
                          <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                          </columnResizePolicy>
                      </TableView>
                  </children>
              </VBox>
         </center>
      </BorderPane>
    </children>
</AnchorPane>
