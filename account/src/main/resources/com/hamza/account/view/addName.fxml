<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <VBox styleClass="dashboard-tile" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <GridPane styleClass="grid-pane-style">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <children>
                        <TextField fx:id="txtCode" editable="false" promptText="Code" GridPane.columnIndex="1"/>
                        <TextField fx:id="txtName" promptText="Name" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtTel" promptText="Tel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtAddress" promptText="Address" GridPane.columnIndex="1"
                                   GridPane.rowIndex="7"/>
                        <TextField fx:id="txtBalance" promptText="Balance" GridPane.columnIndex="1"
                                   GridPane.rowIndex="2"/>
                        <TextField fx:id="txtLimit" promptText="Limit" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        <ComboBox fx:id="comboSelPrice" promptText="Sel Price Type" GridPane.columnIndex="1"
                                  GridPane.rowIndex="5"/>
                        <TextArea fx:id="txtOther" promptText="Other" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
                        <Label fx:id="labelCode" text="Code"/>
                        <Label fx:id="labelName" text="Name" GridPane.rowIndex="1"/>
                        <Label fx:id="labelTel" text="Tel" GridPane.rowIndex="3"/>
                        <Label fx:id="labelAddress" text="Address" GridPane.rowIndex="7"/>
                        <Label fx:id="labelBalance" text="Balance" GridPane.rowIndex="2"/>
                        <Label fx:id="labelLimit" text="Limit" GridPane.rowIndex="4"/>
                        <Label fx:id="labelOthers" text="Other" GridPane.rowIndex="8"/>
                        <Label fx:id="labelSelPrice" text="Sel price" GridPane.rowIndex="5"/>
                        <Label fx:id="labelArea" text="area" GridPane.rowIndex="6"/>
                        <ComboBox fx:id="comboArea" promptText="area" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                    </children>
                </GridPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
