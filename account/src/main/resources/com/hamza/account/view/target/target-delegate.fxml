<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.CheckComboBox?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <AnchorPane>
            <children>
                <VBox layoutX="5.0" layoutY="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <fx:include fx:id="reportsToolbar" source="../include/toolbar-reports.fxml"/>
                        <SplitPane dividerPositions="0.5" orientation="VERTICAL" VBox.vgrow="SOMETIMES">
                            <items>
                                <AnchorPane minHeight="0.0" minWidth="0.0">
                                    <children>
                                        <VBox spacing="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                            <children>
                                                <HBox fx:id="hBox" alignment="CENTER_LEFT" styleClass="dashboard-tile">
                                                    <children>
                                                        <GridPane minHeight="-Infinity" minWidth="-Infinity"
                                                                   HBox.hgrow="SOMETIMES">
                                                            <columnConstraints>
                                                                <ColumnConstraints hgrow="SOMETIMES"
                                                                                   maxWidth="-Infinity"
                                                                                   minWidth="10.0"/>
                                                                <ColumnConstraints hgrow="SOMETIMES"
                                                                                   maxWidth="-Infinity"
                                                                                   minWidth="10.0"/>
                                                                <ColumnConstraints hgrow="SOMETIMES"
                                                                                   maxWidth="-Infinity"
                                                                                   minWidth="10.0"/>
                                                                <ColumnConstraints hgrow="SOMETIMES"
                                                                                   maxWidth="-Infinity"
                                                                                   minWidth="10.0"/>
                                                            </columnConstraints>
                                                            <rowConstraints>
                                                                <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                                vgrow="SOMETIMES"/>
                                                                <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                                vgrow="SOMETIMES"/>
                                                            </rowConstraints>
                                                            <children>
                                                                <Label fx:id="labelName" text="Delegate Name"/>
                                                                <ComboBox fx:id="comboBoxName"
                                                                          maxWidth="1.7976931348623157E308"
                                                                          promptText="name" GridPane.columnIndex="1"/>
                                                                <Label fx:id="labelYear" text="Year"
                                                                       GridPane.columnIndex="2"/>
                                                                <ComboBox fx:id="comboBoxYear"
                                                                          maxWidth="1.7976931348623157E308"
                                                                          promptText="year" GridPane.columnIndex="3"/>
                                                                <Label fx:id="labelMonth" text="Month"
                                                                       GridPane.rowIndex="1"/>
                                                                <CheckComboBox fx:id="comboBoxMonth"
                                                                               maxWidth="1.7976931348623157E308"
                                                                               GridPane.columnIndex="1"
                                                                               GridPane.rowIndex="1"/>
                                                                <Button fx:id="btnSearch" mnemonicParsing="false"
                                                                        prefWidth="70.0" text="Search"
                                                                        GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                                            </children>
                                                        </GridPane>
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="tableView" VBox.vgrow="SOMETIMES">
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </AnchorPane>
                                <AnchorPane minHeight="0.0" minWidth="0.0">
                                    <children>
                                        <TabPane layoutX="5.0" layoutY="5.0" prefHeight="241.0" prefWidth="761.0"
                                                 tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0"
                                                 AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                                 AnchorPane.topAnchor="0.0">
                                            <tabs>
                                                <Tab text="المبيعات">
                                                    <content>
                                                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0"
                                                                    prefWidth="200.0">
                                                            <children>
                                                                <VBox fx:id="boxSales" AnchorPane.bottomAnchor="0.0"
                                                                      AnchorPane.leftAnchor="0.0"
                                                                      AnchorPane.rightAnchor="0.0"
                                                                      AnchorPane.topAnchor="0.0"/>
                                                            </children>
                                                        </AnchorPane>
                                                    </content>
                                                </Tab>
                                                <Tab text="المرتجعات">
                                                    <content>
                                                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0"
                                                                    prefWidth="200.0">
                                                            <children>
                                                                <VBox fx:id="boxSalesRe" AnchorPane.bottomAnchor="0.0"
                                                                      AnchorPane.leftAnchor="0.0"
                                                                      AnchorPane.rightAnchor="0.0"
                                                                      AnchorPane.topAnchor="0.0"/>
                                                            </children>
                                                        </AnchorPane>
                                                    </content>
                                                </Tab>
                                                <Tab text="حسابات العملاء">
                                                    <content>
                                                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0"
                                                                    prefWidth="200.0">
                                                            <children>
                                                                <VBox fx:id="boxAccount" AnchorPane.bottomAnchor="0.0"
                                                                      AnchorPane.leftAnchor="0.0"
                                                                      AnchorPane.rightAnchor="0.0"
                                                                      AnchorPane.topAnchor="0.0"/>
                                                            </children>
                                                        </AnchorPane>
                                                    </content>
                                                </Tab>
                                            </tabs>
                                        </TabPane>
                                    </children>
                                </AnchorPane>
                            </items>
                            <VBox.margin>
                                <Insets bottom="2.0" left="2.0" right="2.0" top="2.0"/>
                            </VBox.margin>
                        </SplitPane>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</StackPane>
