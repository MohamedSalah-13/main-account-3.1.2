<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane minWidth="-Infinity" prefWidth="230.0" styleClass="right-pane-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hamza.account.controller.main.MainRightPaneController">
    <children>
        <VBox spacing="5.0" styleClass="right-pane-container" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
            <MenuButton fx:id="menuButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="modern-menu-button" text="MenuButton">
               <items>
                  <MenuItem fx:id="menuItemChangeName" mnemonicParsing="false" text="Change Name" />
                  <MenuItem fx:id="menuItemChangePass" mnemonicParsing="false" text="Change Password" />
                  <MenuItem fx:id="menuItemLogout" mnemonicParsing="false" text="Logout" />
               </items>
            </MenuButton>

                <Accordion styleClass="main-accordion">
                    <panes>
                        <TitledPane fx:id="paneSales" animated="false" text="Sales">
                            <content>
                                <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                    <content>
                                        <VBox styleClass="side-button-box">
                                            <children>
                                                <Button fx:id="btnSales" mnemonicParsing="false" text="Sales" />
                                                <Button fx:id="btnTotalSale" mnemonicParsing="false" text="Total Sales" />
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </content>
                        </TitledPane>

                        <TitledPane fx:id="panePurchase" animated="false" text="Purchase">
                            <content>
                                <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                    <content>
                                        <VBox styleClass="side-button-box">
                                            <children>
                                                <Button fx:id="btnPurchase" mnemonicParsing="false" text="Purchase" />
                                                <Button fx:id="btnPurchaseRe" mnemonicParsing="false" text="Purchase Re" />
                                                <Button fx:id="btnTotalPurchase" mnemonicParsing="false" text="Total Purchase" />
                                                <Button fx:id="btnTotalPurchaseRe" mnemonicParsing="false" text="Total Purchase Re" />
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </content>
                        </TitledPane>

                        <TitledPane fx:id="paneItems" animated="false" text="Items">
                            <content>
                                <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                    <content>
                                        <VBox styleClass="side-button-box">
                                            <children>
                                                <Button fx:id="btnItems" mnemonicParsing="false" text="Items" />
                                                <Button fx:id="btnAddItem" mnemonicParsing="false" text="Add Item" />
                                                <Button fx:id="btnUnits" mnemonicParsing="false" text="Units" />
                                                <Button fx:id="btnMainGroup" mnemonicParsing="false" text="Main Group" />
                                                <Button fx:id="btnInventory" mnemonicParsing="false" text="Inventory" />
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </content>
                        </TitledPane>

                        <TitledPane fx:id="paneCustom" animated="false" text="Custom">
                            <content>
                                <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                    <content>
                                        <VBox styleClass="side-button-box">
                                            <children>
                                                <Button fx:id="btnCustomer" mnemonicParsing="false" text="Customer" />
                                                <Button fx:id="btnAccountCustom" mnemonicParsing="false" text="Account Customer" />
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </content>
                        </TitledPane>

                        <TitledPane fx:id="paneSuppliers" animated="false" text="Suppliers">
                            <content>
                                <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                    <content>
                                        <VBox styleClass="side-button-box">
                                            <children>
                                                <Button fx:id="btnSuppliers" mnemonicParsing="false" text="Suppliers" />
                                                <Button fx:id="btnAccountSuppliers" mnemonicParsing="false" text="Account Suppliers" />
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </content>
                        </TitledPane>

                        <TitledPane fx:id="paneTreasury" animated="false" text="Treasury">
                            <content>
                                <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                    <content>
                                        <VBox styleClass="side-button-box">
                                            <children>
                                                <Button fx:id="btnTreasuryDetails" mnemonicParsing="false" text="كشف حساب" />
                                                <Button fx:id="btnConvertTreasury" mnemonicParsing="false" text="Convert Treasury" />
                                                <Button fx:id="btnProcess" mnemonicParsing="false" text="Process" />
                                                <Button fx:id="btnExpenses" mnemonicParsing="false" text="Expenses" />
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </content>
                        </TitledPane>

                        <TitledPane fx:id="paneSetting" animated="false" text="Setting">
                            <content>
                                <ScrollPane fitToWidth="true" styleClass="side-scroll">
                                    <content>
                                        <VBox styleClass="side-button-box">
                                            <children>
                                                <Button fx:id="btnHome" mnemonicParsing="false" text="Home" />
                                                <Button fx:id="btnUsers" mnemonicParsing="false" text="Users" />
                                                <Button fx:id="btnBackup" mnemonicParsing="false" text="Backup" />
                                                <Button fx:id="btnClose" mnemonicParsing="false" text="Close" />
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </content>
                        </TitledPane>
                    </panes>
                </Accordion>

                <VBox alignment="BOTTOM_CENTER" spacing="5.0" styleClass="right-footer" VBox.vgrow="ALWAYS">
                    <children>
                        <Text fx:id="txtNameProject" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-account" text="Account System">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Text>
                        <Text fx:id="txtName" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-name" text="Mohamed Salah">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Text>
                        <Text fx:id="txtTel" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-tel" text="01002937820">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Text>
                    </children>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                    </padding>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
