<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>


<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ToolBar>
            <items>
                <Button fx:id="btnRefresh" mnemonicParsing="false" text="تحديث" />
                <Button fx:id="btnPrint" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" text="طباعة" />
            </items>
        </ToolBar>
        <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="SOMETIMES">
            <content>
                <VBox spacing="2.0">
                    <children>
                        <VBox styleClass="dashboard-tile">
                            <children>
                                <GridPane minHeight="-Infinity" minWidth="-Infinity" styleClass="grid-pane-style">
                                    <columnConstraints>
                                        <ColumnConstraints maxWidth="-Infinity" minWidth="10.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <TextField fx:id="textSearch" promptText="بحث" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="comboStock" maxWidth="1.7976931348623157E308" promptText="المخزن" GridPane.columnIndex="1" />
                                        <Label text="المخزن" />
                                        <Label text="بحث" GridPane.rowIndex="1" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                        <Pagination fx:id="pagination" VBox.vgrow="SOMETIMES" />
                        <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" spacing="5.0" styleClass="pane-box-last">
                            <children>
                                <Label text="إجمالى المشتريات" />
                                <Text fx:id="textSumPurchase" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-sum" text="0.0" />
                                <Label text="إجمالى المبيعات" />
                                <Text fx:id="textSumSales" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-sum" text="0.0" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
