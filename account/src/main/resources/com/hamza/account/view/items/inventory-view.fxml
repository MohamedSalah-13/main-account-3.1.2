<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox nodeOrientation="RIGHT_TO_LEFT" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
      <BorderPane styleClass="app-root">
         <top>
                <ToolBar styleClass="items-toolbar" BorderPane.alignment="CENTER">
                    <items>
                        <Button fx:id="btnRefresh" mnemonicParsing="false" styleClass="neutral-button" text="تحديث" />
                        <Button fx:id="btnPrint" mnemonicParsing="false" styleClass="primary-button" text="طباعة" />
                    </items>
                </ToolBar>
         </top>
         <bottom>

                    <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="summary-bar" BorderPane.alignment="CENTER">
                        <children>
                            <Label styleClass="summary-label" text="إجمالي المشتريات" />
                            <Text fx:id="textSumPurchase" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="summary-value" text="0.0" />

                            <Label styleClass="summary-label" text="إجمالي المبيعات" />
                            <Text fx:id="textSumSales" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="summary-value" text="0.0" />
                        </children>
                    </HBox>
         </bottom>
         <center>

                <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="items-scroll-pane" BorderPane.alignment="CENTER">
                    <content>
                        <VBox spacing="5.0">
                            <children>
                                <VBox styleClass="app-card">
                                    <children>
                                        <GridPane hgap="12.0" vgap="12.0">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="110.0" />
                                                <ColumnConstraints hgrow="ALWAYS" minWidth="280.0" />
                                            </columnConstraints>

                                            <children>
                                                <Label styleClass="form-label" text="المخزن" />
                                                <ComboBox fx:id="comboStock" maxWidth="1.7976931348623157E308" promptText="المخزن" GridPane.columnIndex="1" />

                                                <Label styleClass="form-label" text="بحث" GridPane.rowIndex="1" />
                                                <TextField fx:id="textSearch" promptText="بحث" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                            </children>
                                 <rowConstraints>
                                    <RowConstraints />
                                    <RowConstraints />
                                 </rowConstraints>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <Pagination fx:id="pagination" styleClass="modern-pagination" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
         </center>
      </BorderPane>
    </children>
</VBox>
