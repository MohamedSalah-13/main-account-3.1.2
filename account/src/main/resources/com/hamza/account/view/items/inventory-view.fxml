<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox nodeOrientation="RIGHT_TO_LEFT"
      styleClass="items-root"
      stylesheets="@../../css/items-modern.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox spacing="14.0" styleClass="items-container" VBox.vgrow="ALWAYS">
            <children>
                <ToolBar styleClass="items-toolbar">
                    <items>
                        <Button fx:id="btnRefresh" mnemonicParsing="false" text="تحديث" styleClass="neutral-button"/>
                        <Button fx:id="btnPrint" mnemonicParsing="false" text="طباعة" styleClass="primary-button"/>
                    </items>
                </ToolBar>

                <ScrollPane fitToHeight="true"
                            fitToWidth="true"
                            styleClass="items-scroll-pane"
                            VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="14.0">
                            <children>
                                <VBox styleClass="items-card">
                                    <children>
                                        <GridPane hgap="12.0" vgap="12.0">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="110.0"/>
                                                <ColumnConstraints minWidth="280.0" hgrow="ALWAYS"/>
                                            </columnConstraints>

                                            <children>
                                                <Label text="المخزن" styleClass="form-label"/>
                                                <ComboBox fx:id="comboStock"
                                                          maxWidth="1.7976931348623157E308"
                                                          promptText="المخزن"
                                                          GridPane.columnIndex="1"/>

                                                <Label text="بحث"
                                                       styleClass="form-label"
                                                       GridPane.rowIndex="1"/>
                                                <TextField fx:id="textSearch"
                                                           promptText="بحث"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="1"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <Pagination fx:id="pagination"
                                            styleClass="modern-pagination"
                                            VBox.vgrow="ALWAYS"/>

                                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="summary-bar">
                                    <children>
                                        <Label text="إجمالي المشتريات" styleClass="summary-label"/>
                                        <Text fx:id="textSumPurchase"
                                              strokeType="OUTSIDE"
                                              strokeWidth="0.0"
                                              text="0.0"
                                              styleClass="summary-value"/>

                                        <Label text="إجمالي المبيعات" styleClass="summary-label"/>
                                        <Text fx:id="textSumSales"
                                              strokeType="OUTSIDE"
                                              strokeWidth="0.0"
                                              text="0.0"
                                              styleClass="summary-value"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</VBox>