<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <ScrollPane fitToHeight="true" fitToWidth="true" layoutX="5.0" layoutY="5.0" AnchorPane.bottomAnchor="5.0"
                    AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <content>
                <AnchorPane>
                    <children>
                        <VBox spacing="10.0" styleClass="dashboard-tile" AnchorPane.bottomAnchor="5.0"
                              AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
                            <children>
                                <VBox layoutX="10.0" layoutY="10.0" maxHeight="-Infinity" minHeight="-Infinity"
                                      spacing="10.0">
                                    <children>
                                        <GridPane minHeight="-Infinity" minWidth="-Infinity"
                                                  styleClass="grid-pane-style">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                   minWidth="10.0"/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                            </rowConstraints>
                                            <children>
                                                <Label fx:id="labelMain1" text="سعر3" GridPane.rowIndex="1"/>
                                                <Label fx:id="labelSub1" text="سعر1"/>
                                                <Label fx:id="labelType1" text="سعر2" GridPane.columnIndex="2"/>
                                                <TextField fx:id="textPrice2" GridPane.columnIndex="3"/>
                                                <TextField fx:id="textPrice1" GridPane.columnIndex="1"/>
                                                <TextField fx:id="textPrice3" GridPane.columnIndex="1"
                                                           GridPane.rowIndex="1"/>
                                                <Label fx:id="labelMain" text="Main Group" GridPane.rowIndex="2"/>
                                                <ComboBox fx:id="comboMain" disable="true"
                                                          maxWidth="1.7976931348623157E308" promptText="Main"
                                                          GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                                <Label fx:id="labelSub" text="Sub Group" GridPane.rowIndex="3"/>
                                                <ComboBox fx:id="comboSub" maxWidth="1.7976931348623157E308"
                                                          promptText="Sub" GridPane.columnIndex="1"
                                                          GridPane.rowIndex="3"/>
                                                <Label fx:id="labelType" text="Typ" GridPane.columnIndex="2"
                                                       GridPane.rowIndex="3"/>
                                                <ComboBox fx:id="comboType" maxWidth="1.7976931348623157E308"
                                                          promptText="Type" GridPane.columnIndex="3"
                                                          GridPane.rowIndex="3"/>
                                                <CheckBox fx:id="checkActivateBarcodeScale" mnemonicParsing="false"
                                                          text="تفعيل ميزان الباركود" GridPane.columnIndex="1"
                                                          GridPane.rowIndex="4"/>
                                                <Label text="باركود يبدا برقم" GridPane.rowIndex="5"/>
                                                <Label text="عدد ارقام الوزن" GridPane.rowIndex="6"/>
                                                <TextField fx:id="textBarcodeStart" text="00" GridPane.columnIndex="1"
                                                           GridPane.rowIndex="5"/>
                                                <TextField fx:id="textCountScale" text="5" GridPane.columnIndex="1"
                                                           GridPane.rowIndex="6"/>
                                                <Label text="عدد ارقام الباركود" GridPane.columnIndex="2"
                                                       GridPane.rowIndex="5"/>
                                                <Label text="عدد الرقام الصنف" GridPane.columnIndex="2"
                                                       GridPane.rowIndex="6"/>
                                                <TextField fx:id="textCountBarcode" text="13" GridPane.columnIndex="3"
                                                           GridPane.rowIndex="5"/>
                                                <TextField fx:id="textCountItem" text="5" GridPane.columnIndex="3"
                                                           GridPane.rowIndex="6"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                    <padding>
                                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                    </padding>
                                </VBox>
                                <HBox spacing="5.0" VBox.vgrow="SOMETIMES">
                                    <children>
                                        <VBox spacing="20.0">
                                            <children>
                                                <CheckBox fx:id="show2" mnemonicParsing="false" text="Show Tow Label"/>
                                                <CheckBox fx:id="showName" mnemonicParsing="false" selected="true"
                                                          text="Show Name"/>
                                                <CheckBox fx:id="showPrice" mnemonicParsing="false" selected="true"
                                                          text="Show Price"/>
                                                <CheckBox fx:id="showCurrency" mnemonicParsing="false" selected="true"
                                                          text="Show Currency"/>
                                                <CheckBox fx:id="showBarcode" mnemonicParsing="false" selected="true"
                                                          text="Show Barcode"/>
                                            </children>
                                        </VBox>
                                        <Separator orientation="VERTICAL"/>
                                        <VBox alignment="TOP_CENTER" HBox.hgrow="SOMETIMES">
                                            <children>
                                                <BorderPane fx:id="borderPane">
                                                    <center>
                                                        <VBox fx:id="box" alignment="TOP_CENTER" fillWidth="false"
                                                              spacing="5.0">
                                                            <padding>
                                                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                                            </padding>
                                                        </VBox>
                                                    </center>
                                                </BorderPane>
                                            </children>
                                        </VBox>
                                    </children>
                                    <padding>
                                        <Insets left="5.0" right="5.0"/>
                                    </padding>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
