<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane nodeOrientation="RIGHT_TO_LEFT"
            styleClass="app-root"

            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21">
    <children>
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    styleClass="settings-scroll-pane"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"
                    AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="18.0" styleClass="app-container">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="بيانات الشركة" styleClass="settings-title"/>
                                <Label text="تعديل بيانات الشركة والشعار المستخدم في التقارير والفواتير"
                                       styleClass="settings-subtitle"/>
                            </children>
                        </VBox>

                        <HBox spacing="18.0" styleClass="app-card">
                            <children>
                                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <GridPane hgap="14.0" vgap="14.0">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="130.0"/>
                                                <ColumnConstraints minWidth="360.0" hgrow="ALWAYS"/>
                                            </columnConstraints>

                                            <children>
                                                <Label fx:id="labelName" text="Name" styleClass="form-label"/>
                                                <TextField fx:id="textNameCompany"
                                                           styleClass="modern-input"
                                                           GridPane.columnIndex="1"/>

                                                <Label fx:id="labelAddress"
                                                       text="Address"
                                                       styleClass="form-label"
                                                       GridPane.rowIndex="1"/>
                                                <TextField fx:id="textAddress"
                                                           styleClass="modern-input"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="1"/>

                                                <Label fx:id="labelTel"
                                                       text="Tel"
                                                       styleClass="form-label"
                                                       GridPane.rowIndex="2"/>
                                                <TextField fx:id="textTel"
                                                           styleClass="modern-input"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="2"/>

                                                <Label fx:id="labelTax"
                                                       text="Tax"
                                                       styleClass="form-label"
                                                       GridPane.rowIndex="3"/>
                                                <TextField fx:id="textTax"
                                                           styleClass="modern-input"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="3"/>

                                                <Label fx:id="labelCom"
                                                       text="Comm"
                                                       styleClass="form-label"
                                                       GridPane.rowIndex="4"/>
                                                <TextField fx:id="textCom"
                                                           styleClass="modern-input"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="4"/>

                                                <Button fx:id="btnSave"
                                                        mnemonicParsing="false"
                                                        text="Save"
                                                        styleClass="primary-button"
                                                        GridPane.columnIndex="1"
                                                        GridPane.rowIndex="5"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <VBox alignment="TOP_CENTER" spacing="12.0">
                                    <children>
                                        <VBox alignment="CENTER" spacing="8.0" styleClass="image-preview-card">
                                            <children>
                                                <ImageView fx:id="imageView"
                                                           fitHeight="150.0"
                                                           fitWidth="150.0"
                                                           pickOnBounds="true"
                                                           preserveRatio="true"/>
                                            </children>
                                        </VBox>

                                        <HBox alignment="CENTER" spacing="8.0">
                                            <children>
                                                <Button fx:id="btnAddImage"
                                                        mnemonicParsing="false"
                                                        text="Add Image"
                                                        styleClass="success-button"/>
                                                <Button fx:id="btnClearImage"
                                                        mnemonicParsing="false"
                                                        text="Clear"
                                                        styleClass="danger-button"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox fx:id="hbox" styleClass="app-card" VBox.vgrow="ALWAYS"/>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>