<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <ScrollPane fitToHeight="true" fitToWidth="true" layoutX="5.0" layoutY="5.0" AnchorPane.bottomAnchor="5.0"
                    AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <content>
                <AnchorPane>
                    <children>
                        <VBox spacing="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <children>
                                <HBox spacing="5.0" styleClass="dashboard-tile">
                                    <children>
                                        <VBox spacing="10.0" HBox.hgrow="SOMETIMES">
                                            <children>
                                                <GridPane minWidth="-Infinity" styleClass="grid-pane-style">
                                                    <columnConstraints>
                                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"
                                                                           minWidth="10.0"/>
                                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0"/>
                                                    </columnConstraints>
                                                    <rowConstraints>
                                                        <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                        vgrow="SOMETIMES"/>
                                                        <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                        vgrow="SOMETIMES"/>
                                                        <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                        vgrow="SOMETIMES"/>
                                                        <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                        vgrow="SOMETIMES"/>
                                                        <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                        vgrow="SOMETIMES"/>
                                                        <RowConstraints minHeight="10.0" prefHeight="30.0"
                                                                        vgrow="SOMETIMES"/>
                                                    </rowConstraints>
                                                    <children>
                                                        <Label fx:id="labelName" text="Name"/>
                                                        <TextField fx:id="textNameCompany" GridPane.columnIndex="1"/>
                                                        <Label fx:id="labelAddress" text="Address"
                                                               GridPane.rowIndex="1"/>
                                                        <TextField fx:id="textAddress" GridPane.columnIndex="1"
                                                                   GridPane.rowIndex="1"/>
                                                        <Label fx:id="labelTel" text="Tel" GridPane.rowIndex="2"/>
                                                        <TextField fx:id="textTel" GridPane.columnIndex="1"
                                                                   GridPane.rowIndex="2"/>
                                                        <Label fx:id="labelTax" text="Tax" GridPane.rowIndex="3"/>
                                                        <TextField fx:id="textTax" GridPane.columnIndex="1"
                                                                   GridPane.rowIndex="3"/>
                                                        <Label fx:id="labelCom" text="Comm" GridPane.rowIndex="4"/>
                                                        <TextField fx:id="textCom" GridPane.columnIndex="1"
                                                                   GridPane.rowIndex="4"/>
                                                        <Button fx:id="btnSave" mnemonicParsing="false" prefWidth="80.0"
                                                                text="Save" GridPane.columnIndex="1"
                                                                GridPane.rowIndex="5"/>
                                                    </children>
                                                </GridPane>
                                            </children>
                                        </VBox>
                                        <VBox alignment="TOP_CENTER" spacing="5.0">
                                            <children>
                                                <VBox spacing="5.0" styleClass="dashboard-tile" VBox.vgrow="SOMETIMES">
                                                    <children>
                                                        <ImageView fx:id="imageView" fitHeight="150.0" fitWidth="150.0"
                                                                   pickOnBounds="true" preserveRatio="true"/>
                                                    </children>
                                                </VBox>
                                                <HBox alignment="CENTER" spacing="5.0">
                                                    <children>
                                                        <Button fx:id="btnAddImage" mnemonicParsing="false"
                                                                text="Add Image"/>
                                                        <Button fx:id="btnClearImage" layoutX="10.0" layoutY="10.0"
                                                                mnemonicParsing="false" text="Clear"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox fx:id="hbox" styleClass="dashboard-tile" VBox.vgrow="SOMETIMES"/>
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                            </padding>
                        </VBox>
                    </children>
                </AnchorPane>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
