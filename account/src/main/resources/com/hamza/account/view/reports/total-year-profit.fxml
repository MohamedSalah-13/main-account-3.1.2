<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.CheckComboBox?>
<?import java.lang.String?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21">
    <children>
        <VBox prefHeight="400.0" prefWidth="600.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="CENTER" prefHeight="50.0" styleClass="box-title">
                    <children>
                        <Label text="التقرير السنوى"/>
                    </children>
                </VBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label text="السنة"/>
                        <ComboBox fx:id="comboYear" prefWidth="150.0"/>
                        <Label text="الشهور"/>
                        <CheckComboBox fx:id="checkComboBox"/>
                        <Button fx:id="searchButton" mnemonicParsing="false" text="Search"/>
                        <Button fx:id="btnPrint" layoutX="303.0" layoutY="20.0" mnemonicParsing="false" text="Print"/>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </padding>
                    <styleClass>
                        <String fx:value="dashboard-tile"/>
                        <String fx:value="pane-box-last"/>
                    </styleClass>
                </HBox>
                <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="SOMETIMES"/>
            </children>
        </VBox>
    </children>
</AnchorPane>
