<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                  <Label text="التقرير السنوى" textFill="#2c3e50" underline="true">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label text="السنة" />
                        <ComboBox fx:id="comboYear" prefWidth="150.0" />
                        <Button fx:id="searchButton" mnemonicParsing="false" text="Search">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font></Button>
                        <Button fx:id="btnPrintPdf" layoutX="303.0" layoutY="20.0" mnemonicParsing="false" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="تصدير PDF">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font></Button>
                  <Button fx:id="btnExportExcel" layoutX="265.0" layoutY="20.0" mnemonicParsing="false" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="تصدير Excel">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font></Button>
                    </children>
                </HBox>
                <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="SOMETIMES" />
            </children>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
        </VBox>
    </children>
</AnchorPane>
