<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">
    <children>
        <VBox layoutX="5.0" layoutY="5.0" styleClass="dashboard-tile" AnchorPane.bottomAnchor="5.0"
              AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <children>
                <GridPane hgap="20.0" styleClass="grid-pane-style" vgap="20.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0" prefWidth="300.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <children>
                        <Label fx:id="LabelPassOld" text="Old Password"/>
                        <Label fx:id="labelPassNew" text="New Password" GridPane.rowIndex="1"/>
                        <Label fx:id="labelPassRe" text="Confirm Password" GridPane.rowIndex="2"/>
                        <HBox alignment="CENTER_LEFT" minHeight="-Infinity" spacing="2.0" styleClass="box-pass"
                              GridPane.columnIndex="1">
                            <children>
                                <PasswordField fx:id="txtPassOld" HBox.hgrow="SOMETIMES"/>
                                <ImageView fx:id="imagePassOld" fitHeight="25.0" fitWidth="25.0" pickOnBounds="true"
                                           preserveRatio="true"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" minHeight="-Infinity" spacing="2.0" styleClass="box-pass"
                              GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <children>
                                <PasswordField fx:id="txtPassNew" HBox.hgrow="SOMETIMES"/>
                                <ImageView fx:id="imagePassNew" fitHeight="25.0" fitWidth="25.0" pickOnBounds="true"
                                           preserveRatio="true"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" minHeight="-Infinity" spacing="2.0" styleClass="box-pass"
                              GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <children>
                                <PasswordField fx:id="txtPassRe" HBox.hgrow="SOMETIMES"/>
                                <ImageView fx:id="imagePassRe" fitHeight="25.0" fitWidth="25.0" pickOnBounds="true"
                                           preserveRatio="true"/>
                            </children>
                        </HBox>
                    </children>
                </GridPane>
            </children>
        </VBox>
    </children>
    <stylesheets>
        <URL value="@../css/style.css"/>
        <URL value="@../../../../../../../../account/src/main/resources/com/hamza/account/css/loginStyle.css"/>
    </stylesheets>
</AnchorPane>
