<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:id="pane" maxHeight="-Infinity" minHeight="-Infinity"
            prefHeight="30.0" style="-fx-border-color: red; -fx-border-width: 0 0 1 0;"
            stylesheets="@../css/tool_style.css" xmlns="http://javafx.com/javafx/21"
            fx:controller="com.hamza.controlsfx.controller.CloseController">
    <children>
        <HBox alignment="CENTER_LEFT" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <ImageView fx:id="imageView" fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true"/>
                <HBox alignment="CENTER" HBox.hgrow="SOMETIMES">
                    <children>
                        <Label fx:id="title" text="Title"/>
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Button fx:id="btnMinus" mnemonicParsing="false" styleClass="image-tools">
                            <graphic>
                                <ImageView fitHeight="13.0" fitWidth="13.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../image/minus.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="btnResize" mnemonicParsing="false" styleClass="image-tools">
                            <graphic>
                                <ImageView fx:id="viewResize" fitHeight="13.0" fitWidth="13.0" pickOnBounds="true"
                                           preserveRatio="true">
                                    <image>
                                        <Image url="@../image/squareMini.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="btnClose" mnemonicParsing="false" styleClass="image-close">
                            <graphic>
                                <ImageView fitHeight="13.0" fitWidth="13.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../image/cancel.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
