    <queryString language="SQL">
        <![CDATA[SELECT account_system_db.custom.name,
	account_system_db.custom.tel,
	account_system_db.custom.address,
	account_system_db.custom.notes,
	account_system_db.custom.first_balance,
	account_system_db.type_price.name as price_name
FROM account_system_db.type_price
	INNER JOIN account_system_db.custom ON 
	 account_system_db.custom.price_id = account_system_db.type_price.id]]>
    </queryString>
