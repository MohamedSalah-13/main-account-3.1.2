    <parameter name="by_year" class="java.lang.Integer"/>
    <parameter name="by_name" class="java.lang.String"/>
    <parameter name="by_first_month" class="java.lang.Integer"/>
    <parameter name="by_last_month" class="java.lang.Integer"/>
    <queryString language="SQL">
        <![CDATA[SELECT employee_name,
	total_sales_sum,
	total_sales_re_sum,
	Amount,
	target,
	sales_year,
	sales_month,
	commission,
	target_ratio1,
	rate_1
FROM account_system_db.target_delegate
WHERE 
	 account_system_db.target_delegate.sales_year = $P{by_year} 
	 AND ( 
	 account_system_db.target_delegate.employee_name = $P{by_name} 
	 OR $P{by_name} IS NULL ) 
	 AND ( 
	 account_system_db.target_delegate.sales_month BETWEEN $P{by_first_month} AND $P{by_last_month} 
	 OR $P{by_first_month} IS NULL  
	 OR $P{by_last_month} IS NULL ) 
ORDER BY account_system_db.target_delegate.sales_month ASC]]>
    </queryString>
