    <parameter name="transfer_id" class="java.lang.Integer"/>
    <parameter name="transfer_end" class="java.lang.Integer"/>
    <queryString language="SQL">
        <![CDATA[SELECT id,
	transfer_date,
	stock_from,
	name_from,
	stock_to,
	name_to,
	`nameItem`,
	item_id,
	quantity
FROM account_system_db.stock_transfer_view
WHERE
	id BETWEEN  $P{transfer_id} AND $P{transfer_end}]]>
    </queryString>
