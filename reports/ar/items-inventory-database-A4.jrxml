    <parameter name="stock_id" class="java.lang.Integer"/>
    <queryString language="SQL">
        <![CDATA[SELECT account_system_db.quantity_items_table.item_id,
	account_system_db.quantity_items_table.stock_id,
	account_system_db.quantity_items_table.first_balance,
	account_system_db.quantity_items_table.`quantityPurchase`,
	account_system_db.quantity_items_table.`quantitySales`,
	account_system_db.quantity_items_table.`quantityPurchaseRe`,
	account_system_db.quantity_items_table.`quantitySalesRe`,
	account_system_db.quantity_items_table.`fromStock`,
	account_system_db.quantity_items_table.`toStock`,
	account_system_db.items.`nameItem`,
	account_system_db.items.barcode,
	account_system_db.stocks.stock_name
FROM account_system_db.quantity_items_table
	INNER JOIN account_system_db.items ON 
	 account_system_db.items.id = account_system_db.quantity_items_table.item_id 
	INNER JOIN account_system_db.stocks ON 
	 account_system_db.stocks.stock_id = account_system_db.quantity_items_table.stock_id 
WHERE
	account_system_db.quantity_items_table.stock_id= $P!{stock_id} OR $P!{stock_id} IS NULL]]>
    </queryString>
