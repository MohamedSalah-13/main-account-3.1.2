    <parameter name="itemNum" class="java.lang.Integer"/>
    <parameter name="purchase" class="java.lang.Double"/>
    <parameter name="sales" class="java.lang.Double"/>
    <parameter name="purchase_re" class="java.lang.Double"/>
    <parameter name="sales_re" class="java.lang.Double"/>
    <parameter name="first_balance" class="java.lang.Double"/>
