    <parameter name="dateFrom" class="java.lang.String"/>
    <parameter name="dateTo" class="java.lang.String"/>
    <queryString language="SQL">
        <![CDATA[SELECT id,
	invoice_number,
	invoice_date,
	item_num,
	barcode,
	unit_type,
	price,
	quantity,
	discount,
	name_custom,
	table_name,
	`nameItem`,
	unit_name
FROM account_system_db.card_item_view_details
WHERE 
	 account_system_db.card_item_view_details.item_num = $P{itemNum} 
	 	 AND account_system_db.card_item_view_details.invoice_date BETWEEN $P{dateFrom} AND $P{dateTo}
]]>
    </queryString>
